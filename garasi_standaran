<!-- ============================================================
  JAVASCRIPT — hanya untuk:
  1. Toggle sidebar buka/tutup
  2. Toggle sub-menu dropdown
  3. Navigasi antar halaman
  4. Login / logout admin
  5. Tampilan tanggal
  6. Toast notifikasi
  (Tidak ada CRUD, tidak ada localStorage data)
============================================================ -->
<script>

  /* ============================================================
    STATE APLIKASI
  ============================================================ */
  let sidebarOpen = false;   /* sidebar default tertutup */
  let isLoggedIn  = false;   /* status login admin */
  let currentPage = 'dashboard';

  /* ============================================================
    STORAGE — hanya untuk menyimpan status login
  ============================================================ */
  const S = {
    get: (k, def = null) => { try { const v = localStorage.getItem('bpro_' + k); return v !== null ? JSON.parse(v) : def; } catch { return def; } },
    set: (k, v) => { try { localStorage.setItem('bpro_' + k, JSON.stringify(v)); } catch {} }
  };

  /* ============================================================
    TOGGLE SIDEBAR — buka/tutup sidebar
    Mengubah class .closed pada sidebar dan .sidebar-closed pada main
  ============================================================ */
  function toggleSidebar() {
    const sidebar = document.getElementById('sidebar');
    const main    = document.getElementById('main');
    sidebarOpen = !sidebarOpen;

    if (sidebarOpen) {
      sidebar.classList.remove('closed');       /* tampilkan label menu */
      main.classList.remove('sidebar-closed');  /* perluas area konten */
    } else {
      sidebar.classList.add('closed');          /* sembunyikan label, tampil ikon saja */
      main.classList.add('sidebar-closed');     /* sempitkan area konten */
    }
  }

  /* ============================================================
    TOGGLE SUB-MENU — dropdown menu inventori & keuangan
    subId   = id elemen nav-sub
    arrowId = id elemen panah
    e       = event object (untuk stopPropagation)
  ============================================================ */
  function toggleSub(subId, arrowId, e) {
    if (e) e.stopPropagation();

    /* jika sidebar tertutup, buka sidebar dulu lalu buka sub-menu */
    if (!sidebarOpen) {
      toggleSidebar();
      setTimeout(() => _bukaSub(subId, arrowId), 280);
      return;
    }
    _bukaSub(subId, arrowId);
  }

  function _bukaSub(subId, arrowId) {
    const sub   = document.getElementById(subId);
    const arrow = document.getElementById(arrowId);
    const isOpen = sub.classList.contains('open');

    /* tutup semua sub-menu dulu */
    document.querySelectorAll('.nav-sub.open').forEach(el => el.classList.remove('open'));
    document.querySelectorAll('.nav-arrow.open').forEach(el => el.classList.remove('open'));

    /* buka yang diklik jika sebelumnya tertutup */
    if (!isOpen) {
      sub.classList.add('open');
      if (arrow) arrow.classList.add('open');
    }
  }

  /* ============================================================
    GOPAGE — update untuk render modul saat berpindah halaman
  ============================================================ */
  function goPage(pageId, el, title, parent) {
    /* sembunyikan semua halaman */
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));

    /* tampilkan halaman yang dipilih */
    const pg = document.getElementById('page-' + pageId);
    if (pg) pg.classList.add('active');

    /* update breadcrumb */
    const bc = document.getElementById('breadcrumb');
    bc.innerHTML = parent
      ? `<span>Garasi Standaran</span><span class="bc-sep">›</span><span>${parent}</span><span class="bc-sep">›</span><span class="bc-current">${title}</span>`
      : `<span>Garasi Standaran</span><span class="bc-sep">›</span><span class="bc-current">${title}</span>`;

    /* reset highlight semua menu, highlight yang aktif */
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    document.querySelectorAll('.nav-sub-item').forEach(n => n.classList.remove('active'));
    if (el) el.classList.add('active');

    currentPage = pageId;

    /* render ulang modul yang bersangkutan saat halaman dibuka */
    if (pageId === 'masuk')       renderMasuk();
    if (pageId === 'keluar')      { renderKeluar(); const fb = document.getElementById('keluar-filter-bulan'); if (fb && !fb.value) fb.value = hariIni().slice(0,7); }
    if (pageId === 'stok')        renderStok();
    if (pageId === 'alat')        renderAlat();
    if (pageId === 'cashflow')    { renderCashflow(); _initCfBulan(); }
    if (pageId === 'operasional') { renderOps(); const ob = document.getElementById('ops-filter-bulan'); if (ob && !ob.value) ob.value = hariIni().slice(0,7); }
    if (pageId === 'laporan')     { const lb = document.getElementById('lap-bulan'); if (lb && !lb.value) lb.value = hariIni().slice(0,7); renderLaporan(); }
    if (pageId === 'dashboard')   renderDashboard();
  }

  /* ============================================================
    LOGIN ADMIN
  ============================================================ */
  /* buka modal login */
  function openLogin() {
    if (isLoggedIn) {
      /* sudah login — konfirmasi logout */
      if (confirm('Logout dari akun admin?')) doLogout();
      return;
    }
    /* reset form */
    document.getElementById('lm-user').value = '';
    document.getElementById('lm-pass').value = '';
    document.getElementById('lm-error').style.display = 'none';
    document.getElementById('modal-login').classList.add('open');
    setTimeout(() => document.getElementById('lm-user').focus(), 100);
  }

  /* tutup modal login */
  function closeLogin() {
    document.getElementById('modal-login').classList.remove('open');
  }

  /* proses login — validasi username & password */
  function doLogin() {
    const user = document.getElementById('lm-user').value.trim();
    const pass = document.getElementById('lm-pass').value;

    /* kredensial default — akan bisa diubah di pengaturan nanti */
    const validUser = S.get('admin_user', 'Kiong');
    const validPass = S.get('admin_pass', 'bengkel123');

    if (user === validUser && pass === validPass) {
      /* login berhasil */
      isLoggedIn = true;
      S.set('session', true);
      closeLogin();
      updateLoginUI();
      showToast('Login berhasil! Selamat datang, Admin 👋', 'success');
    } else {
      /* login gagal — tampilkan pesan error */
      document.getElementById('lm-error').style.display = 'block';
      document.getElementById('lm-pass').value = '';
      document.getElementById('lm-pass').focus();
    }
  }

  /* proses logout */
  function doLogout() {
    isLoggedIn = false;
    S.set('session', false);
    updateLoginUI();
    showToast('Logout berhasil', 'info');
  }

  /* perbarui UI sesuai status login */
  function updateLoginUI() {
    const tbLabel  = document.getElementById('tb-login-label');
    const sbLabel  = document.getElementById('sb-login-label');
    const badge    = document.getElementById('badge-login');
    const userRole = document.getElementById('sb-userrole');

    if (isLoggedIn) {
      tbLabel.textContent  = 'Logout Admin';
      sbLabel.textContent  = 'Logout Admin';
      badge.style.display  = 'inline';
      userRole.textContent = 'Administrator ✓';
    } else {
      tbLabel.textContent  = 'Login Admin';
      sbLabel.textContent  = 'Login Admin';
      badge.style.display  = 'none';
      userRole.textContent = 'Administrator';
    }
  }

  /* ============================================================
    HELPER — generate ID unik
  ============================================================ */
  function uid() {
    return Date.now().toString(36) + Math.random().toString(36).slice(2,6);
  }

  /* ============================================================
    HELPER — format Rupiah
  ============================================================ */
  function rp(val) {
    return 'Rp ' + Number(val || 0).toLocaleString('id-ID');
  }

  /* ============================================================
    HELPER — tanggal hari ini format YYYY-MM-DD
  ============================================================ */
  function hariIni() {
    return new Date().toISOString().split('T')[0];
  }

  /* ============================================================
    HELPER — format tanggal ke tampilan Indonesia
    "2025-03-13" → "13 Mar 2025"
  ============================================================ */
  function fmtTgl(str) {
    if (!str) return '—';
    const d = new Date(str + 'T00:00:00');
    return d.toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' });
  }

  /* ============================================================
    STATE — variabel halaman barang masuk
  ============================================================ */
  let selectedMasukId = null; /* ID transaksi masuk yang dipilih */
  let hapusTargetId   = null; /* ID transaksi yang akan dihapus */

  /* ============================================================
    KATEGORI DINAMIS — ambil semua kategori unik dari data masuk
    Dipakai untuk autocomplete dan filter dropdown
  ============================================================ */
  // function getKategori() {
  //   const masuk = S.get('masuk', []);
  //   const set   = new Set(masuk.map(m => m.kat).filter(Boolean));
  //   return [...set].sort();
  // }

  function getKategori() {
    const masuk = S.get('masuk', []);
    const stok  = S.get('stok',  []);
    const alat  = S.get('alat',  []);
    const semua = [...masuk, ...stok, ...alat];
    const set   = new Set(semua.map(b => b.kat).filter(Boolean));
    return [...set].sort();
  }

/* ============================================================
    AUTOCOMPLETE KODE BARANG
  ============================================================ */
  function acKode(val) {
    const list  = document.getElementById('ac-kode-list');
    const semua = [...S.get('masuk',[]), ...S.get('stok',[]), ...S.get('alat',[])];
    const unik  = [...new Map(semua.map(b => [b.kode, b])).values()];
    const q     = val.trim().toLowerCase();
    const cocok = q ? unik.filter(b => b.kode.toLowerCase().includes(q)) : unik;
    if (!cocok.length) { list.classList.remove('open'); return; }
    list.innerHTML = cocok.map(b =>
      `<div class="ac-item" onmousedown="pilihKode('${b.kode}')">
         <span class="ac-item-dot"></span>
         <span style="font-family:'JetBrains Mono',monospace;font-size:11px">${b.kode}</span>
         <span style="color:var(--text3);font-size:10px;margin-left:6px">${b.nama}</span>
       </div>`).join('');
    list.classList.add('open');
  }

  /* pilih kode → isi otomatis semua field terkait */
  function pilihKode(kode) {
    const semua = [...S.get('masuk',[]), ...S.get('stok',[]), ...S.get('alat',[])];
    const b = semua.find(x => x.kode === kode);
    if (!b) return;
    document.getElementById('fm-kode').value     = b.kode;
    document.getElementById('fm-nama').value     = b.nama;
    document.getElementById('fm-kat').value      = b.kat;
    document.getElementById('fm-satuan').value   = b.satuan;
    document.getElementById('fm-hbeli').value    = b.hbeli || '';
    document.getElementById('fm-hjual').value    = b.hjual || '';
    document.getElementById('fm-stokmin').value  = b.stokMin || 5;
    document.getElementById('fm-supplier').value = b.supplier || '';
    tutupAcKode();
    updateAlurInfo();
  }

  function tutupAcKode() { document.getElementById('ac-kode-list')?.classList.remove('open'); }

  /* ============================================================
    AUTOCOMPLETE NAMA BARANG
  ============================================================ */
  function acNama(val) {
    const list  = document.getElementById('ac-nama-list');
    const semua = [...S.get('masuk',[]), ...S.get('stok',[]), ...S.get('alat',[])];
    const unik  = [...new Map(semua.map(b => [b.nama, b])).values()];
    const q     = val.trim().toLowerCase();
    const cocok = q ? unik.filter(b => b.nama.toLowerCase().includes(q)) : unik;
    if (!cocok.length) { list.classList.remove('open'); return; }
    list.innerHTML = cocok.map(b =>
      `<div class="ac-item" onmousedown="pilihNama('${b.kode}')">
         <span class="ac-item-dot"></span>${b.nama}
         <span style="color:var(--text3);font-size:10px;margin-left:6px">${b.kode}</span>
       </div>`).join('');
    list.classList.add('open');
  }

  function pilihNama(kode) { pilihKode(kode); tutupAcNama(); }
  function tutupAcNama() { document.getElementById('ac-nama-list')?.classList.remove('open'); }

  /* ============================================================
    AUTOCOMPLETE SUPPLIER
  ============================================================ */
  function acSupplier(val) {
    const list  = document.getElementById('ac-supplier-list');
    const masuk = S.get('masuk', []);
    const unik  = [...new Set(masuk.map(b => b.supplier).filter(Boolean))];
    const q     = val.trim().toLowerCase();
    const cocok = q ? unik.filter(s => s.toLowerCase().includes(q)) : unik;
    if (!cocok.length) { list.classList.remove('open'); return; }
    list.innerHTML = cocok.map(s =>
      `<div class="ac-item" onmousedown="pilihSupplier('${s.replace(/'/g,"\\'")}')">
         <span class="ac-item-dot"></span>${s}
       </div>`).join('');
    list.classList.add('open');
  }

  function pilihSupplier(val) {
    document.getElementById('fm-supplier').value = val;
    tutupAcSupplier();
  }
  function tutupAcSupplier() { document.getElementById('ac-supplier-list')?.classList.remove('open'); }

  /* ============================================================
    AUTOCOMPLETE KATEGORI — tampilkan dropdown saran kategori
    val = nilai yang sedang diketik di input kategori
  ============================================================ */
  function acKategori(val) {
    const list = document.getElementById('ac-kat-list');
    const kats = getKategori();
    const q    = val.trim().toLowerCase();

    /* filter kategori yang cocok dengan input */
    const cocok = q
      ? kats.filter(k => k.toLowerCase().includes(q))
      : kats;

    if (cocok.length === 0) { list.classList.remove('open'); return; }

    list.innerHTML = cocok.map(k => `
      <div class="ac-item" onmousedown="pilihKategori('${k}')">
        <span class="ac-item-dot"></span>${k}
      </div>`).join('');
    list.classList.add('open');
  }

  /* pilih kategori dari dropdown autocomplete */
  function pilihKategori(val) {
    document.getElementById('fm-kat').value = val;
    tutupAc();
    updateAlurInfo(val); /* update info alur berdasarkan kategori */
  }

  /* tutup dropdown autocomplete */
  function tutupAc() {
    const list = document.getElementById('ac-kat-list');
    if (list) list.classList.remove('open');
  }

  /* update teks info alur di form — cek berdasarkan kode INV */
  function updateAlurInfo(kat) {
    const el   = document.getElementById('fm-alur-info');
    if (!el) return;
    const kode = document.getElementById('fm-kode')?.value.trim().toUpperCase() || '';
    const tujuan = kode.startsWith('INV') ? '<b>Inventori Bengkel / Alat Kerja</b>' : '<b>Stok Barang</b>';
    el.innerHTML = `💡 Data ini akan otomatis tersimpan ke: ${tujuan} · <b>Cashflow</b> (pengeluaran) · <b>Laporan</b>`;
  }

  /* hitung dan tampilkan total pembelian saat input berubah */
  function hitungTotal() {
    const qty   = parseInt(document.getElementById('fm-qty')?.value)   || 0;
    const hbeli = parseInt(document.getElementById('fm-hbeli')?.value) || 0;
    /* tampilkan total di judul modal */
    const total = qty * hbeli;
    const info  = document.getElementById('fm-alur-info');
    if (info && total > 0) {
      const ongkir = parseInt(document.getElementById('fm-ongkir')?.value) || 0;
      info.innerHTML = info.innerHTML.replace(/Total:.*?<br>/, '');
    }
  }

  /* ============================================================
    BUKA FORM BARANG MASUK
    id = null  → mode tambah baru
    id = string → mode edit
  ============================================================ */
  function bukaFormMasuk(id) {
    if (!isLoggedIn) {
      showToast('Silakan login admin terlebih dahulu', 'error');
      openLogin();
      return;
    }

    document.getElementById('modal-masuk-title').textContent =
      id ? '✏️ Edit Transaksi Masuk' : '+ Catat Barang Masuk';

    if (id) {
      /* mode edit — isi form dari data yang ada */
      const d = S.get('masuk', []).find(m => m.id === id);
      if (!d) return;
      document.getElementById('fm-id').value       = d.id;
      document.getElementById('fm-tgl').value      = d.tgl;
      document.getElementById('fm-kode').value     = d.kode;
      document.getElementById('fm-nama').value     = d.nama;
      document.getElementById('fm-kat').value      = d.kat;
      document.getElementById('fm-satuan').value   = d.satuan;
      document.getElementById('fm-qty').value      = d.qty;
      document.getElementById('fm-hbeli').value    = d.hbeli;
      document.getElementById('fm-hjual').value    = d.hjual || '';
      document.getElementById('fm-stokmin').value  = d.stokMin || 5;
      document.getElementById('fm-supplier').value = d.supplier || '';
      document.getElementById('fm-ongkir').value   = d.ongkir || '';
      document.getElementById('fm-ket').value      = d.ket || '';
      updateAlurInfo(d.kat);
    } else {
      /* mode tambah — reset form, isi tanggal hari ini */
      document.getElementById('fm-id').value       = '';
      document.getElementById('fm-tgl').value      = hariIni();
      document.getElementById('fm-kode').value     = '';
      document.getElementById('fm-nama').value     = '';
      document.getElementById('fm-kat').value      = '';
      document.getElementById('fm-satuan').value   = '';
      document.getElementById('fm-qty').value      = '';
      document.getElementById('fm-hbeli').value    = '';
      document.getElementById('fm-hjual').value    = '';
      document.getElementById('fm-stokmin').value  = '5';
      document.getElementById('fm-supplier').value = '';
      document.getElementById('fm-ongkir').value   = '';
      document.getElementById('fm-ket').value      = '';
      updateAlurInfo('');
    }

    document.getElementById('modal-masuk').classList.add('open');
    setTimeout(() => document.getElementById('fm-nama').focus(), 100);
  }

  /* tutup form barang masuk */
  function tutupFormMasuk() {
    document.getElementById('modal-masuk').classList.remove('open');
    tutupAc();
  }

  /* ============================================================
    SIMPAN BARANG MASUK — validasi + simpan + alirkan ke modul lain
  ============================================================ */
  function simpanBarangMasuk() {
    /* ambil nilai dari form */
    const tgl      = document.getElementById('fm-tgl').value;
    const kode     = document.getElementById('fm-kode').value.trim();
    const nama     = document.getElementById('fm-nama').value.trim();
    const kat      = document.getElementById('fm-kat').value.trim();
    const satuan   = document.getElementById('fm-satuan').value;
    const qty      = parseInt(document.getElementById('fm-qty').value) || 0;
    const hbeli    = parseInt(document.getElementById('fm-hbeli').value) || 0;
    const hjual    = parseInt(document.getElementById('fm-hjual').value) || 0;
    const stokMin  = parseInt(document.getElementById('fm-stokmin').value) || 5;
    const supplier = document.getElementById('fm-supplier').value.trim();
    const ongkir   = parseInt(document.getElementById('fm-ongkir').value) || 0;
    const ket      = document.getElementById('fm-ket').value.trim();

    /* validasi field wajib */
    if (!tgl)    { showToast('Tanggal wajib diisi', 'error'); return; }
    if (!kode)   { showToast('Kode barang wajib diisi', 'error'); return; }
    if (kode.toUpperCase().startsWith('INV')) { showToast('Kode INV khusus Inventori Bengkel. Gunakan menu Inventori Bengkel.', 'error'); return; }
    if (!nama)   { showToast('Nama barang wajib diisi', 'error'); return; }
    if (!kat)    { showToast('Kategori wajib diisi', 'error'); return; }
    if (!satuan) { showToast('Satuan wajib dipilih', 'error'); return; }
    if (qty < 1) { showToast('Qty harus lebih dari 0', 'error'); return; }
    if (!hbeli)  { showToast('Harga beli wajib diisi', 'error'); return; }

    const total   = qty * hbeli;
    const editId  = document.getElementById('fm-id').value;
    const isAlat  = kode.toUpperCase().startsWith('INV'); /* kode INV → masuk Alat Kerja */

    /* ── buat objek transaksi masuk ── */
    const trx = {
      id: editId || uid(),
      tgl, kode, nama, kat, satuan, qty, hbeli, hjual, stokMin,
      supplier, ongkir, ket,
      total,            /* qty × harga beli */
    };

    /* ══ SIMPAN KE localStorage ══ */

    /* 1. Simpan transaksi masuk */
    const masuk = S.get('masuk', []);
    if (editId) {
      /* edit: ambil data lama untuk menghitung selisih stok */
      const lama = masuk.find(m => m.id === editId);
      const idx  = masuk.findIndex(m => m.id === editId);
      masuk[idx] = trx;

      /* update stok: kurangi qty lama, tambah qty baru */
      // _updateStok(kode, nama, kat, satuan, hjual, stokMin, ket,
      //             trx.qty - (lama?.qty || 0), isAlat);
      
      _updateStok(kode, nama, kat, satuan, hbeli, hjual, stokMin, ket, trx.qty - (lama?.qty||0));

      /* update cashflow: hapus entri lama, buat entri baru */
      _hapusCashflowDariMasuk(editId);
      _catatCashflow(trx);

      showToast(`Transaksi "${nama}" berhasil diperbarui`, 'success');
    } else {
      /* tambah baru */
      masuk.push(trx);

      /* tambah stok item baru atau yang sudah ada */
      // _updateStok(kode, nama, kat, satuan, hjual, stokMin, ket, qty, isAlat);
      _updateStok(kode, nama, kat, satuan, hbeli, hjual, stokMin, ket, qty);

      /* catat ke cashflow — nilai beli + ongkir keduanya masuk sebagai pengeluaran kas */
      _catatCashflow(trx);

      showToast(`Barang "${nama}" berhasil dicatat (+${qty} ${satuan})`, 'success');
    }
    S.set('masuk', masuk);

    tutupFormMasuk();
    selectedMasukId = trx.id;
    _refreshAll();
  }

  /* ============================================================
    _updateStok — tambah/kurangi stok di modul Stok Barang atau Alat Kerja
    kode, nama, kat, satuan, hjual, stokMin, ket = info barang
    Qty = qty yang ditambahkan (positif) atau dikurangi (negatif)
    isAlat     = true jika masuk ke Alat Kerja
  ============================================================ */
  function _updateStok(kode, nama, kat, satuan, hbeli, hjual, stokMin, ket, qty, isAlat) {
    const key  = isAlat ? 'alat' : 'stok';          /* pilih tabel yang sesuai */
    const data = S.get(key, []);
    const idx  = data.findIndex(b => b.kode === kode);

    if (idx >= 0) {
      /* barang sudah ada — tambah stok */
      data[idx].stok    += qty;
      data[idx].stokMin  = stokMin;   /* selalu update nilai minimum */
      data[idx].hjual    = hjual || data[idx].hjual;
      data[idx].hbeli    = hbeli || data[idx].hbeli;
    } else {
      /* barang baru — daftarkan ke tabel */
      data.push({
        id: uid(), kode, nama, kat, satuan,
        stok: qty,
        stokMin,
        hbeli,
        hjual,
        ket,
      });
    }
    S.set(key, data);
  }

  /* ============================================================
    _catatCashflow — catat pengeluaran ke Cashflow
    Nilai pembelian + ongkir keduanya mengurangi kas di Cashflow
  ============================================================ */
  function _catatCashflow(trx) {
    const cf = S.get('cashflow', []);

    /* entri 1: nilai pembelian barang → pengeluaran kas */
    cf.push({
      id:        uid(),
      refId:     trx.id,
      tgl:       trx.tgl,
      tipe:      'keluar',
      kategori:  'Pembelian Stok',
      deskripsi: `Beli ${trx.nama} (${trx.qty} ${trx.satuan})${trx.supplier ? ' dari ' + trx.supplier : ''}`,
      nominal:   trx.total,
      sumber:    'barang-masuk',
    });

    /* entri 2: ongkos kirim/terima → pengeluaran kas terpisah (jika ada) */
    if (trx.ongkir > 0) {
      cf.push({
        id:        uid(),
        refId:     trx.id,           /* refId sama agar ikut terhapus saat transaksi dihapus */
        tgl:       trx.tgl,
        tipe:      'keluar',
        kategori:  'Ongkos Kirim / Terima',
        deskripsi: `Ongkir pembelian ${trx.nama}${trx.supplier ? ' dari ' + trx.supplier : ''}`,
        nominal:   trx.ongkir,
        sumber:    'barang-masuk',
      });
    }

    S.set('cashflow', cf);
  }

  /* hapus semua entri cashflow yang berasal dari transaksi masuk tertentu */
  function _hapusCashflowDariMasuk(refId) {
    S.set('cashflow', S.get('cashflow', []).filter(c => c.refId !== refId));
  }

  /* hapus semua entri operasional yang berasal dari transaksi masuk tertentu */
  function _hapusOperasionalDariMasuk(refId) {
    S.set('operasional', S.get('operasional', []).filter(o => o.refId !== refId));
  }

  /* ============================================================
    RENDER STOK BARANG — tampilkan rekap stok dari localStorage

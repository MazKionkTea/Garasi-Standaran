  /* status stok berdasarkan saldo vs minimum */
  function _stokStatus(b) {
    if (b.stok <= 0)         return { key: 'habis',   label: 'Habis',   badge: 'b-red',    color: 'var(--red)' };
    if (b.stok <= b.stokMin) return { key: 'menipis', label: 'Menipis', badge: 'b-yellow', color: 'var(--yellow)' };
    return                          { key: 'aman',    label: 'Aman',    badge: 'b-accent', color: 'var(--accent)' };
  }

  /* tampilkan detail stok di panel kanan */
  function selectStok(id) {
    selectedStokId = id;
    const b = S.get('stok', []).find(x => x.id === id);
    if (!b) return;

    /* hitung total masuk dan keluar dari riwayat transaksi */
    const totalMasuk  = S.get('masuk',  []).filter(m => m.kode === b.kode).reduce((a, m) => a + m.qty, 0);
    const totalKeluar = S.get('keluar', []).filter(k => k.kode === b.kode).reduce((a, k) => a + k.qty, 0);
    const st  = _stokStatus(b);
    const pct = b.stokMin > 0 ? Math.min(100, Math.round((b.stok / (b.stokMin * 3)) * 100)) : 100;
    const barColor = st.key === 'aman' ? 'var(--accent)' : st.key === 'menipis' ? 'var(--yellow)' : 'var(--red)';

    document.getElementById('detail-empty-stok').style.display   = 'none';
    document.getElementById('detail-content-stok').style.display = 'block';
    document.getElementById('ds-nama').textContent  = b.nama;
    document.getElementById('ds-kode').textContent  = `${b.kode} · ${b.kat}`;
    document.getElementById('ds-kat').textContent   = b.kat;
    document.getElementById('ds-stok').textContent  = `${b.stok} ${b.satuan}`;
    document.getElementById('ds-stok').style.color  = st.color;
    document.getElementById('ds-bar').style.width   = pct + '%';
    document.getElementById('ds-bar').style.background = barColor;
    document.getElementById('ds-bar-label').textContent = `Min: ${b.stokMin} ${b.satuan} · Status: ${st.label}`;
    document.getElementById('ds-masuk').textContent  = `+${totalMasuk} ${b.satuan}`;
    document.getElementById('ds-keluar').textContent = `-${totalKeluar} ${b.satuan}`;
    document.getElementById('ds-hbeli').textContent  = b.hbeli ? rp(b.hbeli) : '—';
    document.getElementById('ds-hjual').textContent  = b.hjual ? rp(b.hjual)  : '—';
    document.getElementById('ds-nilai').textContent  = rp(b.stok * (b.hjual || 0));
    document.getElementById('ds-ket').textContent    = b.ket || '—';

    renderStok(); /* re-render untuk update highlight */
  }


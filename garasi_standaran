          <td><span class="badge b-gray">${b.kat}</span></td>
          <td style="font-weight:700;font-family:'JetBrains Mono',monospace;color:${st.color}">
            ${b.stok} <span style="font-size:10px;color:var(--text3);font-weight:400">${b.satuan}</span></td>
          <td class="td-mono" style="color:var(--text3)">${b.stokMin}</td>
          <td class="td-mono" style="color:var(--accent)">${rp(b.hjual)}</td>
          <td><span class="badge ${st.badge}">${st.label}</span></td>
          <td><div class="td-actions">
            <button class="btn btn-ghost btn-sm btn-icon"
              onclick="event.stopPropagation();bukaEditStok('${b.id}')" title="Edit">✏️</button>
            <button class="btn btn-red btn-sm btn-icon"
              onclick="event.stopPropagation();konfirmasiHapusStok('${b.id}','${b.nama.replace(/'/g,"\\'")}')">🗑️</button>
          </div></td>
        </tr>`;

      }).join('');

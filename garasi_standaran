    /* update filter kategori */
    const sel = document.getElementById('stok-filter-kat');
    if (sel) {
      const cur  = sel.value;
      const kats = [...new Set(stok.map(b => b.kat))].sort();
      sel.innerHTML = `<option value="">Semua Kategori</option>` +
        kats.map(k => `<option ${k === cur ? 'selected' : ''}>${k}</option>`).join('');
    }

    /* update footer */
    const nilaiTotal = filtered.reduce((a, b) => a + b.stok * (b.hbeli || 0), 0);
    const el = document.getElementById('stok-count');
    if (el) el.textContent = `${filtered.length} jenis barang`;

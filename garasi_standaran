  let selectedStokId = null;

  function exportStokJSON() {
    const stok = S.get('stok', []);
    if (stok.length === 0) { showToast('Belum ada data stok untuk diekspor', 'error'); return; }
    const blob = new Blob([JSON.stringify(stok, null, 2)], { type: 'application/json' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = `stok-barang-${hariIni()}.json`;
    a.click();
    URL.revokeObjectURL(url);
    showToast(`${stok.length} item berhasil diekspor`, 'success');
  }


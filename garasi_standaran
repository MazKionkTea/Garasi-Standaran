  /* ============================================================
    RENDER CASHFLOW — rekap semua pemasukan & pengeluaran kas
  ============================================================ */
  function renderCashflow() {
    const cf      = S.get('cashflow', []);
    const search  = document.getElementById('cf-search')?.value.toLowerCase().trim() || '';
    const tipeFil = document.getElementById('cf-filter-tipe')?.value || '';
    const bulFil  = document.getElementById('cf-filter-bulan')?.value || '';

    const filtered = cf.filter(c => {
      const matchSearch = !search || [c.deskripsi, c.kategori].join(' ').toLowerCase().includes(search);
      const matchTipe   = !tipeFil || c.tipe === tipeFil;
      const matchBul    = !bulFil  || c.tgl.startsWith(bulFil);
      return matchSearch && matchTipe && matchBul;
    }).sort((a, b) => b.tgl.localeCompare(a.tgl));

    const tbody = document.getElementById('tbody-cashflow');
    if (!tbody) return;

    if (filtered.length === 0) {
      tbody.innerHTML = `<tr><td colspan="6"><div class="tbl-empty">
        <div class="tbl-empty-icon">💰</div>
        <p>${cf.length === 0
          ? 'Belum ada data cashflow.<br>Data akan muncul otomatis setelah ada transaksi <b>Barang Masuk</b>.'
          : 'Tidak ada transaksi yang cocok dengan filter.'}</p>
      </div></td></tr>`;
    } else {
      tbody.innerHTML = filtered.map(c => `
        <tr>
          <td class="td-mono">${fmtTgl(c.tgl)}</td>
          <td><span class="badge ${c.tipe === 'masuk' ? 'b-accent' : 'b-red'}">
            ${c.tipe === 'masuk' ? '↑ Masuk' : '↓ Keluar'}</span></td>
          <td><span class="badge b-gray">${c.kategori}</span></td>
          <td style="font-size:11px;color:var(--text2)">${c.deskripsi}</td>
          <td class="td-mono" style="font-weight:600;color:${c.tipe === 'masuk' ? 'var(--accent)' : 'var(--red)'}">
            ${c.tipe === 'masuk' ? '+' : '-'}${rp(c.nominal)}</td>
          <td style="font-size:10px;color:var(--text3)">${c.sumber || '—'}</td>
        </tr>`).join('');
    }

    /* hitung ringkasan untuk bulan yang dipilih (atau semua jika tidak difilter) */
    const cfBulan = bulFil ? cf.filter(c => c.tgl.startsWith(bulFil)) : cf;
    const totalMasuk  = cfBulan.filter(c => c.tipe === 'masuk').reduce((a, c) => a + c.nominal, 0);
    const totalKeluar = cfBulan.filter(c => c.tipe === 'keluar').reduce((a, c) => a + c.nominal, 0);
    const saldo       = totalMasuk - totalKeluar;

    const elTM = document.getElementById('cf-total-masuk');
    const elTK = document.getElementById('cf-total-keluar');
    const elSD = document.getElementById('cf-saldo');
    if (elTM) elTM.textContent = rp(totalMasuk);
    if (elTK) elTK.textContent = rp(totalKeluar);
    if (elSD) {
      elSD.textContent = rp(Math.abs(saldo));
      elSD.style.color = saldo >= 0 ? 'var(--accent)' : 'var(--red)';
    }

    const elCount = document.getElementById('cf-count');
    const elFooter = document.getElementById('cf-footer-saldo');
    if (elCount)  elCount.textContent  = `${filtered.length} transaksi`;
    if (elFooter) elFooter.textContent = `Saldo: ${rp(saldo)}`;
  }


  /* ============================================================
    LAPORAN — render ringkasan bulanan
  ============================================================ */
  function renderLaporan() {
    const bulan = document.getElementById('lap-bulan')?.value || hariIni().slice(0,7);
    const masuk  = S.get('masuk',  []).filter(m => m.tgl.startsWith(bulan));
    const keluar = S.get('keluar', []).filter(k => k.tgl.startsWith(bulan));
    const ops    = S.get('operasional', []).filter(o => o.tgl.startsWith(bulan));

    const pemasukan       = keluar.reduce((a,k) => a + k.total, 0);
    const pengeluaranStok = masuk.reduce((a,m) => a + m.total + (m.ongkir||0), 0);
    const biayaOps        = ops.reduce((a,o) => a + o.nominal, 0);
    const laba            = pemasukan - pengeluaranStok - biayaOps;

    /* update kartu ringkasan */
    _setEl('lap-pemasukan',       rp(pemasukan));
    _setEl('lap-pengeluaran-stok', rp(pengeluaranStok));
    _setEl('lap-operasional',     rp(biayaOps));
    const elLaba = document.getElementById('lap-laba');
    const elSub  = document.getElementById('lap-laba-sub');
    if (elLaba) { elLaba.textContent = rp(Math.abs(laba)); elLaba.style.color = laba >= 0 ? 'var(--accent)' : 'var(--red)'; }
    if (elSub)  elSub.textContent = laba >= 0 ? '✅ Untung' : '⚠️ Rugi';

    /* list barang masuk */
    _setEl('lap-masuk-count', `${masuk.length} transaksi`);
    const lm = document.getElementById('lap-list-masuk');
    if (lm) lm.innerHTML = masuk.length === 0
      ? `<div class="card-empty" style="padding:20px 0">Tidak ada barang masuk bulan ini</div>`
      : masuk.map(m => `<div style="display:flex;justify-content:space-between;
           padding:7px 0;border-bottom:1px solid var(--border);font-size:12px">
          <div><b>${m.nama}</b><br><span style="color:var(--text3);font-size:10px">${m.kode} · ${fmtTgl(m.tgl)}</span></div>
          <div style="text-align:right"><span style="color:var(--accent)">+${m.qty} ${m.satuan}</span><br>
            <span style="font-family:'JetBrains Mono',monospace;font-size:10px">${rp(m.total)}</span></div>
        </div>`).join('');

    /* list barang keluar */
    _setEl('lap-keluar-count', `${keluar.length} transaksi`);
    const lk = document.getElementById('lap-list-keluar');
    if (lk) lk.innerHTML = keluar.length === 0
      ? `<div class="card-empty" style="padding:20px 0">Tidak ada barang keluar bulan ini</div>`
      : keluar.map(k => `<div style="display:flex;justify-content:space-between;
           padding:7px 0;border-bottom:1px solid var(--border);font-size:12px">
          <div><b>${k.nama}</b><br><span style="color:var(--text3);font-size:10px">${k.kode} · ${fmtTgl(k.tgl)}</span></div>
          <div style="text-align:right"><span style="color:var(--red)">-${k.qty} ${k.satuan}</span><br>
            <span style="font-family:'JetBrains Mono',monospace;font-size:10px">${rp(k.total)}</span></div>
        </div>`).join('');

    /* list operasional */
    _setEl('lap-ops-count', `${ops.length} entri`);
    const lo = document.getElementById('lap-list-ops');
    if (lo) lo.innerHTML = ops.length === 0
      ? `<div class="card-empty" style="padding:20px 0">Tidak ada biaya operasional bulan ini</div>`
      : ops.map(o => `<div style="display:flex;justify-content:space-between;
           padding:7px 0;border-bottom:1px solid var(--border);font-size:12px">
          <div><b>${o.deskripsi}</b><br><span style="color:var(--text3);font-size:10px">${o.kat} · ${fmtTgl(o.tgl)}</span></div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--red)">-${rp(o.nominal)}</div>
        </div>`).join('');
  }


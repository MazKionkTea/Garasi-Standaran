  /* render line chart 7 hari — nominal rupiah masuk vs keluar */
  function renderChart(masuk, keluar, inv = [], ops = []) {
    const wrap = document.getElementById('chart-placeholder');
    if (!wrap) return;

    const days = Array.from({length: 7}, (_, i) => {
      const d = new Date(); d.setDate(d.getDate() - 6 + i);
      return d.toISOString().split('T')[0];
    });

    /* hitung nominal per hari */
    const dataMasuk  = days.map(d => keluar.filter(k => k.tgl === d).reduce((a, k) => a + (k.total||0), 0));
    const dataKeluar = days.map(d => [
      ...masuk.filter(m => m.tgl === d),
      ...inv.filter(i => i.tglBeli === d),
      ...ops.filter(o => o.tgl === d),
    ].reduce((a, x) => a + (x.total || x.nominal || 0), 0));
    const maxVal     = Math.max(...dataMasuk, ...dataKeluar, 1);

    const W = 100; /* % lebar per segment */
    const H = 120; /* tinggi area grafik px */
    const pad = 10; /* padding kiri kanan */

    /* konversi nilai ke koordinat Y (0 = atas, H = bawah) */
    const toY = v => H - Math.round((v / maxVal) * (H - 10)) - 5;
    const toX = i => pad + Math.round((i / 6) * (100 - pad * 2));

    /* buat polyline points */
    const ptsMasuk  = days.map((_, i) => `${toX(i)},${toY(dataMasuk[i])}`).join(' ');
    const ptsKeluar = days.map((_, i) => `${toX(i)},${toY(dataKeluar[i])}`).join(' ');

    /* buat area polygon (tutup ke bawah) */
    const areaMasuk  = `${toX(0)},${H} ` + days.map((_, i) => `${toX(i)},${toY(dataMasuk[i])}`).join(' ')  + ` ${toX(6)},${H}`;
    const areaKeluar = `${toX(0)},${H} ` + days.map((_, i) => `${toX(i)},${toY(dataKeluar[i])}`).join(' ') + ` ${toX(6)},${H}`;

    /* label hari */
    const labels = days.map((d, i) => {
      const lbl     = new Date(d + 'T00:00:00').toLocaleDateString('id-ID', {weekday:'short'});
      const isToday = d === hariIni();
      return `<div style="position:absolute;bottom:0;left:${toX(i)}%;transform:translateX(-50%);
                font-size:10px;color:${isToday ? 'var(--accent)' : 'var(--text3)'};
                font-weight:${isToday ? '700' : '400'}">${lbl}</div>`;
    }).join('');

    /* tooltip dots */
    const dotsMasuk  = days.map((d, i) => dataMasuk[i] > 0
      ? `<circle cx="${toX(i)}" cy="${toY(dataMasuk[i])}" r="3"
           fill="var(--accent)" stroke="var(--bg)" stroke-width="1.5">
           <title>+${rp(dataMasuk[i])}</title></circle>` : '').join('');
    const dotsKeluar = days.map((d, i) => dataKeluar[i] > 0
      ? `<circle cx="${toX(i)}" cy="${toY(dataKeluar[i])}" r="3"
           fill="var(--red)" stroke="var(--bg)" stroke-width="1.5">
           <title>-${rp(dataKeluar[i])}</title></circle>` : '').join('');

    wrap.innerHTML = `
      <div style="position:relative;width:100%;height:${H + 24}px">
        <svg viewBox="0 0 100 ${H}" preserveAspectRatio="none"
             style="position:absolute;top:0;left:0;width:100%;height:${H}px;overflow:visible">
          <defs>
            <linearGradient id="gradMasuk" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.15"/>
              <stop offset="100%" stop-color="var(--accent)" stop-opacity="0"/>
            </linearGradient>
            <linearGradient id="gradKeluar" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="var(--red)" stop-opacity="0.15"/>
              <stop offset="100%" stop-color="var(--red)" stop-opacity="0"/>
            </linearGradient>
          </defs>
          <!-- area -->
          <polygon points="${areaMasuk}"  fill="url(#gradMasuk)"/>
          <polygon points="${areaKeluar}" fill="url(#gradKeluar)"/>
          <!-- garis -->
          <polyline points="${ptsMasuk}"  fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>
          <polyline points="${ptsKeluar}" fill="none" stroke="var(--red)"    stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>
          <!-- dots -->
          ${dotsMasuk}${dotsKeluar}
        </svg>
        <!-- label hari -->
        <div style="position:absolute;bottom:0;left:0;right:0;height:20px">${labels}</div>
      </div>`;
  }

  /* ============================================================
    ALERT DROPDOWN TOPBAR — buka/tutup dan render isi
  ============================================================ */
  function toggleAlertDropdown() {
    const dd = document.getElementById('alert-dropdown');
    dd.classList.toggle('open');
    /* tutup saat klik di luar */
    if (dd.classList.contains('open')) {
      setTimeout(() => document.addEventListener('click', _closeAlertOnOutside), 10);
    }
  }

  function _closeAlertOnOutside(e) {
    const wrap = document.getElementById('tb-alert-wrap');
    if (!wrap.contains(e.target)) {
      document.getElementById('alert-dropdown').classList.remove('open');
      document.removeEventListener('click', _closeAlertOnOutside);
    }
  }

  /* render isi dropdown: semua stok yang habis atau menipis */
  function _renderAlertDropdown(stok) {
    const items = stok
      .filter(b => b.stok <= b.stokMin)
      .sort((a, b) => a.stok - b.stok); /* urut dari yang paling kritis */

    const body  = document.getElementById('alert-dd-body');
    const count = document.getElementById('alert-dd-count');
    if (!body) return;

    count.textContent = `${items.length} item`;
    body.innerHTML = items.map(b => {
      const habis   = b.stok <= 0;
      const warna   = habis ? 'var(--red)' : 'var(--yellow)';
      const label   = habis ? 'HABIS' : 'Menipis';
      return `<div class="alert-item" onclick="bukaStokDariAlert('${b.id}')">
        <div class="alert-item-left">
          <div class="alert-item-name">${b.nama}</div>
          <div class="alert-item-sub">${b.kode} · ${b.kat}</div>
        </div>
        <div>
          <div class="alert-item-stok" style="color:${warna}">${b.stok} ${b.satuan}</div>
          <div style="font-size:9px;text-align:right;color:${warna}">${label}</div>
        </div>
      </div>`;
    }).join('');
  }

  /* klik item di dropdown → buka halaman Stok Barang dan highlight item */
  function bukaStokDariAlert(stokId) {
    document.getElementById('alert-dropdown').classList.remove('open');
    /* navigasi ke stok */
    const navStok = document.querySelector('[onclick*="goPage(\'stok\'"]');
    goPage('stok', navStok, 'Stok Barang', 'Inventori');
    /* highlight item setelah render */
    setTimeout(() => selectStok(stokId), 100);
  }

  /* render list alert stok menipis — card di dashboard */
  function renderAlertList(stok) {
    const wrap = document.querySelector('#page-dashboard .dash-grid .card:last-child .card-body');
    if (!wrap) return;
    const low = stok.filter(b => b.stok <= b.stokMin).sort((a, b) => a.stok - b.stok);
    if (low.length === 0) {
      wrap.innerHTML = `<div class="card-empty"><div class="card-empty-icon">✅</div>
        ${stok.length === 0 ? 'Belum ada data stok.<br>Mulai dari menu <b>Barang Masuk</b>.' : 'Semua stok dalam kondisi aman.'}</div>`;
      return;
    }
    wrap.innerHTML = low.slice(0, 8).map(b => {
      const habis = b.stok <= 0;
      const pct   = b.stokMin > 0 ? Math.min(100, Math.round((b.stok / b.stokMin) * 100)) : 0;
      const warna = habis ? 'var(--red)' : 'var(--yellow)';
      return `<div onclick="bukaStokDariAlert('${b.id}')"
                   style="display:flex;align-items:center;gap:10px;padding:8px 0;
                          border-bottom:1px solid var(--border);cursor:pointer;border-radius:6px;padding:8px"
                   onmouseover="this.style.background='var(--surface2)'"
                   onmouseout="this.style.background=''">
        <div style="font-size:18px;flex-shrink:0">${habis ? '🔴' : '🟡'}</div>
        <div style="flex:1;min-width:0">
          <div style="font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${b.nama}</div>
          <div style="font-size:10px;color:var(--text3)">${b.kode} · ${b.kat}</div>
          <div style="height:3px;background:var(--surface3);border-radius:2px;margin-top:4px;overflow:hidden">
            <div style="height:100%;width:${pct}%;background:${warna};border-radius:2px"></div>
          </div>
        </div>
        <div style="text-align:right;flex-shrink:0">
          <div style="font-size:13px;font-weight:700;color:${warna};font-family:'JetBrains Mono',monospace">${b.stok}</div>
          <div style="font-size:9px;color:var(--text3)">${b.satuan} / min ${b.stokMin}</div>
        </div>
      </div>`;
    }).join('') +
    (low.length > 8 ? `<div style="text-align:center;padding:8px 0;font-size:11px;color:var(--text3)">+${low.length - 8} item lainnya — lihat di Stok Barang</div>` : '');
  }

  /* render grid kategori di dashboard */
  function renderCatGrid(stok, alat) {
    const grid = document.querySelector('#page-dashboard .cat-grid');
    if (!grid) return;
    const semua = [...stok, ...alat];
    if (semua.length === 0) {
      grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;color:var(--text3);font-size:11px;padding:24px 0">
        Belum ada data. Tambahkan barang melalui menu <b>Barang Masuk</b>.</div>`;
      return;
    }
    /* grup per kategori */
    const kats = {};
    semua.forEach(b => { if (!kats[b.kat]) kats[b.kat] = []; kats[b.kat].push(b); });
    grid.innerHTML = Object.entries(kats).map(([kat, items]) => `
      <div class="cat-card" onclick="goPage('stok',null,'Stok Barang','Inventori')">
        <div class="cat-icon">📦</div>
        <div class="cat-name">${kat}</div>
        <div class="cat-label">${items.length} jenis barang</div>
      </div>`).join('');
  }

  /* set default bulan filter cashflow ke bulan ini */
  function _initCfBulan() {
    const el = document.getElementById('cf-filter-bulan');
    if (el && !el.value) el.value = hariIni().slice(0, 7);
  }

  /* update stats card ids — tambah id ke elemen yang sudah ada */
  function _patchStatCards() {
    const cards = document.querySelectorAll('.stat-card');
    const ids   = ['sc-total','sc-menipis','sc-nilai','sc-aktivitas'];
    cards.forEach((c, i) => { if (ids[i]) c.id = ids[i]; });
  }

  /* ============================================================
    TOAST NOTIFICATION
    msg  = pesan
    type = 'success' | 'error' | 'info'
  ============================================================ */
  function showToast(msg, type = 'info') {
    const icons = { success: '✅', error: '❌', info: 'ℹ️' };
    const el = document.createElement('div');
    el.className = `toast ${type}`;
    el.innerHTML = `<span>${icons[type]}</span><span>${msg}</span>`;
    document.getElementById('toast-wrap').appendChild(el);
    setTimeout(() => { el.style.opacity = '0'; el.style.transition = 'opacity 0.3s'; }, 2800);
    setTimeout(() => el.remove(), 3200);
  }

  /* ============================================================
    TANGGAL — isi elemen tanggal di topbar & dashboard
  ============================================================ */
  function setDates() {
    const opts = { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' };
    const str  = new Date().toLocaleDateString('id-ID', opts);
    document.getElementById('tb-date').textContent   = str;
    document.getElementById('dash-date').textContent = str;
  }

  /* ============================================================
    TUTUP MODAL — klik area luar modal
  ============================================================ */
  document.getElementById('modal-login').addEventListener('click', function(e) {
    if (e.target === this) closeLogin();
  });

  /* ESC — tutup semua modal */
  document.addEventListener('keydown', e => {
    if (e.key !== 'Escape') return;
    closeLogin();
    tutupFormMasuk();
    tutupFormKeluar();
    tutupFormOps();
    tutupEditStok();
    tutupModalHapus();
  });

  /* ============================================================
    INISIALISASI
  ============================================================ */
  function init() {
    setDates();
    _patchStatCards();
    _initCfBulan();
    renderDashboard();

    if (S.get('session', false)) {
      isLoggedIn = true;
      updateLoginUI();
    }

    /* tutup modal saat klik area luar */
    ['modal-masuk','modal-keluar','modal-ops','modal-hapus','modal-login','modal-edit-stok'].forEach(id => {
      const el = document.getElementById(id);
      if (!el) return;
      el.addEventListener('click', function(e) {
        if (e.target !== this) return;
        if (id === 'modal-login')  closeLogin();
        if (id === 'modal-masuk')  tutupFormMasuk();
        if (id === 'modal-keluar') tutupFormKeluar();
        if (id === 'modal-ops')    tutupFormOps();
        if (id === 'modal-hapus')  tutupModalHapus();
        if (id === 'modal-edit-stok') tutupEditStok();
      });
    });

    /* set filter bulan default ke bulan ini */
    ['masuk-filter-bulan','keluar-filter-bulan','ops-filter-bulan'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.value = hariIni().slice(0, 7);
    });
  }

  init();

</script>
</body>
</html>

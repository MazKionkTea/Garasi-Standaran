    /* update filter kategori */
    const sel = document.getElementById('ops-filter-kat');
    if (sel) {
      const cur  = sel.value;
      const allK = [...new Set([...OPS_KAT_DEFAULT, ...ops.map(o => o.kat)])].sort();
      sel.innerHTML = `<option value="">Semua Kategori</option>` +
        allK.map(k => `<option ${k === cur ? 'selected' : ''}>${k}</option>`).join('');
    }

    /* update ringkasan cards */
    const opsBulan = ops.filter(o => o.tgl.startsWith(bulFil || hariIni().slice(0,7)));
    const totalBln = opsBulan.reduce((a,o) => a + o.nominal, 0);
    const jenisSet = new Set(opsBulan.map(o => o.kat));
    const elTB = document.getElementById('ops-total-bulan');
    const elJns = document.getElementById('ops-jenis');
    const elTrx = document.getElementById('ops-trx-count');
    if (elTB)  elTB.textContent  = rp(totalBln);
    if (elJns) elJns.textContent = jenisSet.size || '—';
    if (elTrx) elTrx.textContent = opsBulan.length || '—';
    const elFT = document.getElementById('ops-footer-total');
    const elFC = document.getElementById('ops-count');
    if (elFT) elFT.textContent = `Total: ${rp(filtered.reduce((a,o)=>a+o.nominal,0))}`;
    if (elFC) elFC.textContent = `${filtered.length} entri`;
  }

  /* autocomplete kategori operasional */
  function acKategoriOps(val) {
    const list = document.getElementById('ac-ops-list');
    const ops  = S.get('operasional', []);
    const existing = [...new Set([...OPS_KAT_DEFAULT, ...ops.map(o => o.kat)])];
    const q    = val.trim().toLowerCase();
    const cocok = q ? existing.filter(k => k.toLowerCase().includes(q)) : existing;

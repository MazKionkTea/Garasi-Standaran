<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Garasi Standaran — Sistem Manajemen Bengkel</title>

  <!-- ============================================================
    FONT: Outfit (UI) + JetBrains Mono (angka/kode)
  ============================================================ -->
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <style>

    /* ============================================================
      CSS VARIABLES — warna dan ukuran global
    ============================================================ */
    :root {
      --bg:             #080B12;
      --bg2:            #0D1017;
      --bg3:            #111520;
      --surface:        #161B28;
      --surface2:       #1C2235;
      --surface3:       #222840;
      --border:         rgba(255,255,255,0.06);
      --border2:        rgba(255,255,255,0.12);
      --border3:        rgba(255,255,255,0.18);
      --text:           #E2E6F0;
      --text2:          #7C85A0;
      --text3:          #404660;
      --accent:         #9fef00;   /* lime neon — warna utama */
      --accent-d:       #7bc800;
      --accent-g:       rgba(159,239,0,0.10);
      --accent-g2:      rgba(159,239,0,0.18);
      --red:            #EF4444;
      --red-g:          rgba(239,68,68,0.10);
      --yellow:         #F59E0B;
      --yellow-g:       rgba(245,158,11,0.10);
      --blue:           #3B82F6;
      --blue-g:         rgba(59,130,246,0.10);
      --green:          #22C55E;
      --green-g:        rgba(34,197,94,0.10);
      --purple:         #A855F7;
      --purple-g:       rgba(168,85,247,0.10);

      --sidebar-closed: 58px;
      --sidebar-open:   240px;
      --topbar-h:       56px;
      --radius:         10px;
      --radius-lg:      14px;
      --transition:     0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* ============================================================
      RESET
    ============================================================ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      min-height: 100vh;
      overflow-x: hidden;
    }
    button { cursor: pointer; font-family: 'Outfit', sans-serif; border: none; outline: none; }
    input, select, textarea { font-family: 'Outfit', sans-serif; outline: none; }
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-thumb { background: var(--surface3); border-radius: 4px; }

    /* ============================================================
      SIDEBAR
      Default: tertutup (.closed) — hanya tampil ikon
      Toggle: tombol ☰ di topbar
    ============================================================ */
    .sidebar {
      position: fixed;
      top: 0; left: 0; bottom: 0;
      width: var(--sidebar-open);
      background: var(--bg2);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      z-index: 300;
      overflow-x: hidden;
      overflow-y: auto;           /* sidebar bisa di-scroll saat menu bertambah */
      transition: width var(--transition);
    }

    /* state tertutup */
    .sidebar.closed { width: var(--sidebar-closed); }

    /* tekstur titik-titik halus di latar sidebar */
    .sidebar::before {
      content: '';
      position: absolute; inset: 0;
      pointer-events: none;
      background-image: radial-gradient(circle, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size: 22px 22px;
      z-index: 0;
    }
    .sidebar > * { position: relative; z-index: 1; }

    /* ── Logo ── */
    .sb-logo {
      display: flex; align-items: center; gap: 10px;
      padding: 16px 11px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      min-height: var(--topbar-h);
      overflow: hidden;
    }
    .sb-logo-icon {
      width: 34px; height: 34px; border-radius: 9px;
      background: linear-gradient(135deg, var(--accent), #4ade80);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; flex-shrink: 0;
      box-shadow: 0 4px 14px rgba(159,239,0,0.3);
    }
    .sb-logo-text {
      overflow: hidden; white-space: nowrap;
      transition: opacity var(--transition), width var(--transition);
    }
    .sidebar.closed .sb-logo-text { opacity: 0; width: 0; }
    .sb-logo-name { font-size: 15px; font-weight: 800; letter-spacing: -0.3px; }
    .sb-logo-sub  { font-size: 9px; color: var(--text3); margin-top: 1px; }

    /* ── Info user ── */
    .sb-user {
      margin: 10px 8px 0;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 9px 10px;
      display: flex; align-items: center; gap: 8px;
      flex-shrink: 0; overflow: hidden;
      transition: padding var(--transition);
    }
    .sidebar.closed .sb-user { padding: 9px 12px; justify-content: center; }
    .sb-user-avatar {
      width: 28px; height: 28px; border-radius: 7px;
      background: linear-gradient(135deg, var(--accent), #4ade80);
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; flex-shrink: 0;
      color: #000; font-weight: 700;
    }
    .sb-user-info {
      overflow: hidden; white-space: nowrap;
      transition: opacity var(--transition), width var(--transition);
    }
    .sidebar.closed .sb-user-info { opacity: 0; width: 0; }
    .sb-user-name { font-size: 12px; font-weight: 600; }
    .sb-user-role {
      font-size: 9px; color: var(--accent);
      font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;
    }

    /* ── Label grup menu ── */
    .sb-section { padding: 14px 8px 2px; flex-shrink: 0; }
    .sb-section-label {
      font-size: 9px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 1.2px; color: var(--text3);
      padding: 0 10px; margin-bottom: 3px;
      white-space: nowrap; overflow: hidden;
      transition: opacity var(--transition);
    }
    .sidebar.closed .sb-section-label { opacity: 0; }

    /* ── Item menu ── */
    .nav-item {
      display: flex; align-items: center; gap: 9px;
      padding: 8px 10px; border-radius: 8px;
      cursor: pointer;
      color: var(--text2); font-size: 13px; font-weight: 500;
      border: 1px solid transparent;
      margin-bottom: 1px; position: relative;
      overflow: hidden; white-space: nowrap;
      transition: background var(--transition), color var(--transition), border-color var(--transition);
    }
    .nav-item:hover { background: var(--surface); color: var(--text); }
    .nav-item.active {
      background: var(--accent-g); color: var(--accent);
      border-color: rgba(159,239,0,0.18);
    }
    /* garis indikator kiri */
    .nav-item.active::before {
      content: '';
      position: absolute; left: 0; top: 50%; transform: translateY(-50%);
      width: 3px; height: 16px;
      background: var(--accent); border-radius: 0 3px 3px 0;
    }
    .nav-icon  { font-size: 15px; width: 20px; text-align: center; flex-shrink: 0; }
    .nav-label { flex: 1; transition: opacity var(--transition); overflow: hidden; }
    .sidebar.closed .nav-label { opacity: 0; }

    /* badge notifikasi */
    .nav-badge {
      font-size: 9px; font-weight: 700;
      font-family: 'JetBrains Mono', monospace;
      padding: 2px 5px; border-radius: 8px;
      flex-shrink: 0;
      transition: opacity var(--transition);
    }
    .sidebar.closed .nav-badge { opacity: 0; }
    .nb-red   { background: var(--red);    color: white; }
    .nb-green { background: var(--green);  color: white; }
    .nb-gray  { background: var(--surface3); color: var(--text2); }

    /* ── Sub-menu dropdown dalam sidebar ── */
    .nav-sub {
      overflow: hidden;
      max-height: 0;              /* tersembunyi secara default */
      transition: max-height 0.3s ease;
    }
    .nav-sub.open { max-height: 300px; }
    .sidebar.closed .nav-sub { max-height: 0 !important; }

    .nav-sub-item {
      display: flex; align-items: center; gap: 8px;
      padding: 7px 10px 7px 36px;
      border-radius: 7px; cursor: pointer;
      font-size: 12px; color: var(--text2); font-weight: 400;
      margin-bottom: 1px; white-space: nowrap; overflow: hidden;
      transition: background var(--transition), color var(--transition);
    }
    .nav-sub-item:hover { background: var(--surface); color: var(--text); }
    .nav-sub-item.active { color: var(--accent); font-weight: 600; }
    .nav-sub-dot {
      width: 5px; height: 5px; border-radius: 50%;
      background: var(--text3); flex-shrink: 0;
      transition: background var(--transition);
    }
    .nav-sub-item.active .nav-sub-dot { background: var(--accent); }

    /* panah dropdown */
    .nav-arrow {
      font-size: 10px; color: var(--text3);
      transition: transform 0.25s ease, opacity var(--transition);
      flex-shrink: 0;
    }
    .nav-arrow.open { transform: rotate(90deg); }
    .sidebar.closed .nav-arrow { opacity: 0; }

    /* ── Divider ── */
    .sb-divider { height: 1px; background: var(--border); margin: 8px 8px; flex-shrink: 0; }

    /* ── Footer sidebar ── */
    .sb-footer {
      margin-top: auto;
      padding: 10px 8px;
      border-top: 1px solid var(--border);
      flex-shrink: 0;
    }
    .sb-version {
      font-size: 9px; color: var(--text3); text-align: center;
      font-family: 'JetBrains Mono', monospace;
      white-space: nowrap; overflow: hidden;
      transition: opacity var(--transition);
    }
    .sidebar.closed .sb-version { opacity: 0; }

    /* ============================================================
      MAIN AREA — konten kanan sidebar
    ============================================================ */
    .main {
      margin-left: var(--sidebar-open);
      min-height: 100vh;
      display: flex; flex-direction: column;
      transition: margin-left var(--transition);
    }
    .main.sidebar-closed { margin-left: var(--sidebar-closed); }

    /* ============================================================
      TOPBAR — sticky di atas
    ============================================================ */
    .topbar {
      position: sticky; top: 0; z-index: 200;
      height: var(--topbar-h);
      background: rgba(8,11,18,0.9);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 12px;
      padding: 0 20px; flex-shrink: 0;
    }

    /* tombol toggle sidebar */
    .tb-toggle {
      width: 34px; height: 34px; border-radius: 8px;
      background: var(--surface); border: 1px solid var(--border);
      color: var(--text2);
      display: flex; align-items: center; justify-content: center;
      font-size: 15px; flex-shrink: 0;
      transition: all 0.15s;
    }
    .tb-toggle:hover { border-color: var(--border2); color: var(--text); }

    /* breadcrumb */
    .tb-breadcrumb {
      display: flex; align-items: center; gap: 5px;
      font-size: 12px; color: var(--text3); flex-shrink: 0;
    }
    .tb-breadcrumb .bc-sep { opacity: 0.4; }
    .tb-breadcrumb .bc-current { color: var(--text); font-weight: 600; }

    /* kolom pencarian global */
    .tb-search {
      position: relative; flex: 1; max-width: 320px;
    }
    .tb-search input {
      width: 100%;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 8px; padding: 7px 12px 7px 32px;
      color: var(--text); font-size: 12px;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .tb-search input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(159,239,0,0.1);
    }
    .tb-search input::placeholder { color: var(--text3); }
    .tb-search-icon {
      position: absolute; left: 9px; top: 50%; transform: translateY(-50%);
      color: var(--text3); font-size: 13px; pointer-events: none;
    }

    /* elemen kanan topbar */
    .tb-right { margin-left: auto; display: flex; align-items: center; gap: 10px; }

    /* tanggal */
    .tb-date {
      font-size: 11px; color: var(--text3);
      font-family: 'JetBrains Mono', monospace; white-space: nowrap;
    }

    /* alert stok */
    .tb-alert {
      display: flex; align-items: center; gap: 5px;
      background: var(--red-g); border: 1px solid rgba(239,68,68,0.25);
      color: var(--red); padding: 5px 10px; border-radius: 7px;
      font-size: 11px; font-weight: 500; cursor: pointer;
      white-space: nowrap; transition: all 0.15s;
      animation: tbPulse 2.5s infinite;
    }
    @keyframes tbPulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.25); }
      50%       { box-shadow: 0 0 0 5px rgba(239,68,68,0); }
    }
    .tb-alert:hover { background: rgba(239,68,68,0.18); }

    /* dropdown popup list stok menipis dari topbar alert */
    .alert-dropdown {
      position: absolute; top: calc(var(--topbar-h) + 6px); right: 0;
      width: 300px; background: var(--surface);
      border: 1px solid rgba(239,68,68,0.3); border-radius: var(--radius-lg);
      box-shadow: 0 16px 48px rgba(0,0,0,0.5);
      z-index: 400; display: none;
      animation: modalIn 0.2s ease;
    }
    .alert-dropdown.open { display: block; }
    .alert-dropdown-header {
      padding: 10px 14px 8px;
      border-bottom: 1px solid var(--border);
      font-size: 11px; font-weight: 700; color: var(--red);
      display: flex; align-items: center; justify-content: space-between;
    }
    .alert-dropdown-body { max-height: 280px; overflow-y: auto; padding: 6px 0; }
    .alert-item {
      display: flex; align-items: center; justify-content: space-between;
      padding: 7px 14px; gap: 10px;
      transition: background 0.1s; cursor: pointer;
    }
    .alert-item:hover { background: var(--surface2); }
    .alert-item-left { flex: 1; min-width: 0; }
    .alert-item-name { font-size: 12px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .alert-item-sub  { font-size: 10px; color: var(--text3); margin-top: 1px; }
    .alert-item-stok { font-family: 'JetBrains Mono',monospace; font-size: 12px; font-weight: 700; text-align: right; white-space: nowrap; }
    .alert-dropdown-footer {
      padding: 8px 14px; border-top: 1px solid var(--border);
      font-size: 10px; color: var(--text3); text-align: center;
    }

    /* tombol login admin di topbar */
    .tb-login-btn {
      display: flex; align-items: center; gap: 6px;
      background: var(--accent-g); border: 1px solid rgba(159,239,0,0.25);
      color: var(--accent); padding: 6px 12px; border-radius: 7px;
      font-size: 11px; font-weight: 600;
      transition: all 0.15s; white-space: nowrap;
    }
    .tb-login-btn:hover { background: var(--accent-g2); }

    /* ============================================================
      CONTENT AREA
    ============================================================ */
    .content { flex: 1; padding: 22px 22px 48px; overflow-x: hidden; }

    /* ============================================================
      PAGES — setiap halaman menu
    ============================================================ */
    .page { display: none; animation: pgIn 0.25s ease; }
    .page.active { display: block; }
    @keyframes pgIn {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ============================================================
      PAGE HEADER — judul + tombol aksi
    ============================================================ */
    .pg-header {
      display: flex; align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 20px; gap: 12px; flex-wrap: wrap;
    }
    .pg-title { font-size: 20px; font-weight: 800; letter-spacing: -0.5px; }
    .pg-sub   { font-size: 12px; color: var(--text3); margin-top: 3px; }

    /* ============================================================
      STATS CARDS — 4 kartu angka di dashboard
    ============================================================ */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px; margin-bottom: 20px;
    }
    .stat-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 18px 18px 16px;
      position: relative; overflow: hidden;
      transition: border-color 0.2s, transform 0.2s; cursor: default;
    }
    .stat-card:hover { border-color: var(--border2); transform: translateY(-2px); }
    /* lingkaran dekoratif pojok kanan bawah */
    .stat-card::after {
      content: '';
      position: absolute; bottom: -18px; right: -18px;
      width: 72px; height: 72px; border-radius: 50%; opacity: 0.07;
    }
    .stat-card.c-accent::after { background: var(--accent); }
    .stat-card.c-red::after    { background: var(--red); }
    .stat-card.c-blue::after   { background: var(--blue); }
    .stat-card.c-yellow::after { background: var(--yellow); }
    .stat-label {
      font-size: 10px; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.6px; color: var(--text3); margin-bottom: 10px;
    }
    .stat-value {
      font-size: 28px; font-weight: 800; letter-spacing: -1.5px; line-height: 1;
    }
    .stat-card.c-accent .stat-value { color: var(--accent); }
    .stat-card.c-red    .stat-value { color: var(--red); }
    .stat-card.c-blue   .stat-value { color: var(--blue); }
    .stat-card.c-yellow .stat-value { color: var(--yellow); }
    .stat-icon { position: absolute; top: 16px; right: 16px; font-size: 22px; opacity: 0.4; }
    .stat-sub  { font-size: 10px; color: var(--text3); margin-top: 6px; }

    /* ============================================================
      DASHBOARD GRID — 2 kolom bawah stats
    ============================================================ */
    .dash-grid {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 14px;
    }

    /* kartu umum */
    .card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius-lg); overflow: hidden;
    }
    .card-header {
      padding: 14px 18px 12px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
    }
    .card-title { font-size: 13px; font-weight: 700; }
    .card-sub   { font-size: 10px; color: var(--text3); margin-top: 2px; }
    .card-body  { padding: 16px 18px; }

    /* grafik batang */
    .chart-wrap {
      display: flex; align-items: flex-end; gap: 8px;
      height: 130px; padding: 0 2px;
    }
    .chart-col {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; gap: 5px;
      height: 100%; justify-content: flex-end;
    }
    .chart-bars-pair {
      display: flex; gap: 2px; align-items: flex-end; width: 100%;
    }
    .chart-bar {
      flex: 1; border-radius: 3px 3px 0 0; min-height: 4px;
    }
    /* bar kosong — tampilan placeholder grafik */
    .bar-empty { background: var(--surface3); height: 4px !important; }
    .chart-day {
      font-size: 9px; color: var(--text3);
      font-family: 'JetBrains Mono', monospace; text-align: center;
    }
    .chart-legend { display: flex; gap: 14px; margin-top: 12px; }
    .cl-item { display: flex; align-items: center; gap: 5px; font-size: 10px; color: var(--text2); }
    .cl-dot  { width: 8px; height: 8px; border-radius: 2px; }

    /* placeholder kosong di dalam kartu */
    .card-empty {
      text-align: center; padding: 28px 20px;
      color: var(--text3); font-size: 11px; line-height: 1.6;
    }
    .card-empty-icon { font-size: 28px; margin-bottom: 8px; opacity: 0.2; }

    /* kartu kategori di dashboard */
    .cat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
      gap: 10px; margin-top: 14px;
    }
    .cat-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 14px 14px 12px;
      cursor: pointer; transition: border-color 0.2s, transform 0.2s;
    }
    .cat-card:hover { border-color: var(--accent); transform: translateY(-2px); }
    .cat-icon  { font-size: 22px; margin-bottom: 8px; }
    .cat-name  { font-size: 11px; font-weight: 600; }
    .cat-label { font-size: 9px; color: var(--text3); margin-top: 4px; }

    /* ============================================================
      SPLIT VIEW — list kiri + detail kanan
    ============================================================ */
    .split-view {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 14px; align-items: start;
    }

    /* panel list kiri */
    .split-list {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius-lg); overflow: hidden;
    }

    /* panel detail kanan — sticky */
    .split-detail { position: sticky; top: calc(var(--topbar-h) + 20px); }
    .detail-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius-lg); overflow: hidden;
      min-height: 400px;
    }

    /* placeholder panel detail — belum ada item dipilih */
    .detail-empty {
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      min-height: 400px; text-align: center;
      color: var(--text3); padding: 30px;
    }
    .detail-empty .de-icon { font-size: 40px; margin-bottom: 14px; opacity: 0.2; }
    .detail-empty p { font-size: 11px; line-height: 1.7; }

    /* ── Toolbar tabel: search + filter + tombol ── */
    .tbl-toolbar {
      display: flex; align-items: center; gap: 8px;
      padding: 12px 14px; border-bottom: 1px solid var(--border);
      flex-wrap: wrap;
    }
    .tbl-search { position: relative; flex: 1; min-width: 160px; }
    .tbl-search input {
      width: 100%; background: var(--bg3);
      border: 1px solid var(--border); border-radius: 7px;
      padding: 7px 10px 7px 30px; color: var(--text); font-size: 12px;
      transition: border-color 0.2s;
    }
    .tbl-search input:focus { border-color: var(--accent); outline: none; }
    .tbl-search input::placeholder { color: var(--text3); }
    .tbl-search-icon {
      position: absolute; left: 9px; top: 50%; transform: translateY(-50%);
      color: var(--text3); font-size: 12px; pointer-events: none;
    }
    .tbl-select {
      background: var(--bg3); border: 1px solid var(--border);
      border-radius: 7px; padding: 7px 10px;
      color: var(--text2); font-size: 12px; cursor: pointer;
    }
    .tbl-select:focus { border-color: var(--accent); outline: none; }
    .tbl-select option { background: var(--bg2); }

    /* ── Tabel data ── */
    .tbl-wrap   { overflow-x: auto; }
    .tbl-scroll { max-height: 520px; overflow-y: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead { position: sticky; top: 0; z-index: 10; }
    thead th {
      background: var(--bg3); padding: 9px 12px; text-align: left;
      font-size: 10px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.7px; color: var(--text3);
      border-bottom: 1px solid var(--border); white-space: nowrap;
    }
    tbody tr { border-bottom: 1px solid var(--border); transition: background 0.1s; }
    tbody tr:last-child { border-bottom: none; }

    /* placeholder baris kosong di tabel */
    .tbl-empty { text-align: center; padding: 48px 20px; color: var(--text3); }
    .tbl-empty-icon { font-size: 32px; margin-bottom: 8px; opacity: 0.2; }
    .tbl-empty p { font-size: 11px; line-height: 1.6; }

    /* footer jumlah baris */
    .tbl-footer {
      padding: 9px 14px; border-top: 1px solid var(--border);
      font-size: 10px; color: var(--text3);
      display: flex; align-items: center; justify-content: space-between;
      font-family: 'JetBrains Mono', monospace;
    }

    /* ============================================================
      BADGE
    ============================================================ */
    .badge {
      display: inline-flex; align-items: center;
      font-size: 9px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.4px; padding: 2px 7px;
      border-radius: 5px; white-space: nowrap;
    }
    .b-accent { background: var(--accent-g);  color: var(--accent); border: 1px solid rgba(159,239,0,0.2); }
    .b-red    { background: var(--red-g);     color: var(--red);    border: 1px solid rgba(239,68,68,0.2); }
    .b-yellow { background: var(--yellow-g);  color: var(--yellow); border: 1px solid rgba(245,158,11,0.2); }
    .b-blue   { background: var(--blue-g);    color: var(--blue);   border: 1px solid rgba(59,130,246,0.2); }
    .b-gray   { background: var(--surface2);  color: var(--text2);  border: 1px solid var(--border); }

    /* ============================================================
      BUTTON
    ============================================================ */
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 7px 14px; border-radius: 7px;
      font-size: 12px; font-weight: 600;
      transition: all 0.15s; white-space: nowrap;
      border: none; cursor: pointer;
    }
    .btn-accent { background: var(--accent); color: #000; }
    .btn-accent:hover { background: var(--accent-d); transform: translateY(-1px); }
    .btn-ghost {
      background: var(--surface2); border: 1px solid var(--border2); color: var(--text2);
    }
    .btn-ghost:hover { border-color: var(--border3); color: var(--text); }
    .btn-red {
      background: var(--red-g); border: 1px solid rgba(239,68,68,0.25); color: var(--red);
    }
    .btn-red:hover { background: rgba(239,68,68,0.18); }
    .btn-sm { padding: 5px 10px; font-size: 11px; }

    /* ============================================================
      COMING SOON — halaman belum dibuat
    ============================================================ */
    .coming-soon {
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      min-height: 380px; text-align: center; padding: 40px;
    }
    .cs-icon  { font-size: 52px; margin-bottom: 16px; opacity: 0.25; }
    .cs-title { font-size: 18px; font-weight: 700; color: var(--text2); margin-bottom: 8px; }
    .cs-sub   { font-size: 12px; color: var(--text3); line-height: 1.6; max-width: 300px; }
    .cs-badge {
      display: inline-flex; align-items: center; gap: 6px;
      margin-top: 16px;
      background: var(--accent-g); border: 1px solid rgba(159,239,0,0.2);
      color: var(--accent); padding: 6px 14px;
      border-radius: 20px; font-size: 11px; font-weight: 600;
    }

    /* ============================================================
      MODAL LOGIN ADMIN
    ============================================================ */
    .modal-overlay {
      display: none; position: fixed; inset: 0; z-index: 900;
      background: rgba(0,0,0,0.65); backdrop-filter: blur(6px);
      align-items: center; justify-content: center; padding: 20px;
    }
    .modal-overlay.open { display: flex; }

    .login-modal {
      width: 100%; max-width: 380px;
      background: var(--surface); border: 1px solid var(--border2);
      border-radius: 18px; padding: 36px 32px;
      box-shadow: 0 32px 80px rgba(0,0,0,0.6);
      animation: modalIn 0.3s cubic-bezier(0.34,1.56,0.64,1);
    }
    @keyframes modalIn {
      from { opacity: 0; transform: scale(0.9) translateY(20px); }
      to   { opacity: 1; transform: scale(1) translateY(0); }
    }
    .lm-logo  { text-align: center; margin-bottom: 28px; }
    .lm-icon  {
      width: 56px; height: 56px; border-radius: 15px;
      background: linear-gradient(135deg, var(--accent), #4ade80);
      display: flex; align-items: center; justify-content: center;
      font-size: 24px; margin: 0 auto 12px;
      box-shadow: 0 8px 24px rgba(159,239,0,0.3);
    }
    .lm-title { font-size: 18px; font-weight: 800; }
    .lm-sub   { font-size: 11px; color: var(--text3); margin-top: 3px; }
    .lm-form  { display: flex; flex-direction: column; gap: 12px; }
    .lm-label {
      font-size: 10px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.8px; color: var(--text2);
      display: block; margin-bottom: 5px;
    }
    .lm-input {
      width: 100%; background: var(--bg3);
      border: 1px solid var(--border2); border-radius: 9px;
      padding: 11px 13px; color: var(--text); font-size: 13px;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .lm-input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(159,239,0,0.12);
    }
    .lm-input::placeholder { color: var(--text3); }
    .lm-btn {
      width: 100%; padding: 12px; border-radius: 9px;
      background: var(--accent); color: #000;
      font-size: 13px; font-weight: 700;
      transition: all 0.2s; margin-top: 4px;
    }
    .lm-btn:hover { background: var(--accent-d); transform: translateY(-1px); }
    .lm-cancel {
      width: 100%; padding: 10px; border-radius: 9px;
      background: transparent; border: 1px solid var(--border2);
      color: var(--text2); font-size: 12px; transition: all 0.15s;
    }
    .lm-cancel:hover { background: var(--surface2); color: var(--text); }
    /* pesan error login — tersembunyi secara default */
    .lm-error {
      background: var(--red-g); border: 1px solid rgba(239,68,68,0.25);
      color: var(--red); border-radius: 7px; padding: 8px 11px;
      font-size: 11px; text-align: center; display: none;
    }
    .lm-hint {
      text-align: center; font-size: 10px; color: var(--text3);
      margin-top: 10px; line-height: 1.6;
    }
    .lm-hint b { color: var(--text2); }

    /* ============================================================
      TOAST NOTIFICATION
    ============================================================ */
    .toast-wrap {
      position: fixed; bottom: 22px; right: 22px; z-index: 999;
      display: flex; flex-direction: column; gap: 8px; pointer-events: none;
    }
    .toast {
      display: flex; align-items: center; gap: 9px;
      background: var(--surface2); border: 1px solid var(--border2);
      border-radius: 9px; padding: 11px 14px;
      font-size: 12px; min-width: 240px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
      animation: toastIn 0.3s ease; pointer-events: all;
    }
    @keyframes toastIn {
      from { opacity: 0; transform: translateX(20px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    .toast.success { border-left: 3px solid var(--accent); }
    .toast.error   { border-left: 3px solid var(--red); }
    .toast.info    { border-left: 3px solid var(--blue); }

    /* ============================================================
      MODAL FORM — tambah/edit barang masuk
    ============================================================ */
    .modal-box {
      width: 100%; max-width: 560px;
      background: var(--surface); border: 1px solid var(--border2);
      border-radius: var(--radius-lg); max-height: 92vh; overflow-y: auto;
      box-shadow: 0 32px 80px rgba(0,0,0,0.6);
      animation: modalIn 0.25s cubic-bezier(0.34,1.56,0.64,1);
    }
    .modal-header {
      padding: 18px 20px 14px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; background: var(--surface); z-index: 10;
    }
    .modal-title  { font-size: 15px; font-weight: 700; }
    .modal-close  {
      background: var(--surface2); border: 1px solid var(--border);
      color: var(--text2); border-radius: 6px; padding: 4px 9px;
      font-size: 13px; transition: all 0.15s;
    }
    .modal-close:hover { color: var(--text); border-color: var(--border2); }
    .modal-body   { padding: 20px; }
    .modal-footer {
      padding: 14px 20px 18px; border-top: 1px solid var(--border);
      display: flex; gap: 8px; justify-content: flex-end;
      position: sticky; bottom: 0; background: var(--surface); z-index: 10;
    }

    /* grid form dua kolom */
    .form-grid  { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .form-full  { grid-column: 1 / -1; }
    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-label {
      font-size: 10px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.7px; color: var(--text2);
    }
    .form-label span { color: var(--red); margin-left: 2px; }
    .form-control {
      background: var(--bg3); border: 1px solid var(--border2);
      border-radius: 8px; padding: 9px 11px;
      color: var(--text); font-size: 13px; width: 100%;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .form-control:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(159,239,0,0.1);
      outline: none;
    }
    .form-control::placeholder { color: var(--text3); }
    textarea.form-control {
      resize: vertical;
      min-height: 72px;
      line-height: 1.5;
    }
    select.form-control { cursor: pointer; }
    select.form-control option { background: var(--bg2); }
    .form-hint { font-size: 10px; color: var(--text3); margin-top: 2px; }

    /* ── Autocomplete kategori ── */
    .autocomplete-wrap { position: relative; }
    .autocomplete-list {
      position: absolute; top: 100%; left: 0; right: 0; z-index: 500;
      background: var(--surface2); border: 1px solid var(--border2);
      border-radius: 8px; margin-top: 3px;
      max-height: 180px; overflow-y: auto;
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      display: none;
    }
    .autocomplete-list.open { display: block; }
    .ac-item {
      padding: 8px 12px; font-size: 12px; cursor: pointer;
      color: var(--text2); transition: background 0.1s, color 0.1s;
      display: flex; align-items: center; gap: 8px;
    }
    .ac-item:hover { background: var(--surface3); color: var(--text); }
    .ac-item-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--accent); flex-shrink: 0;
    }

    /* ── Info box ongkos kirim di form ── */
    .form-info {
      background: var(--bg3); border: 1px solid var(--border);
      border-radius: 8px; padding: 10px 12px;
      font-size: 11px; color: var(--text3); line-height: 1.6;
    }
    .form-info b { color: var(--text2); }

    /* ── Konfirmasi hapus ── */
    .confirm-box {
      width: 100%; max-width: 360px;
      background: var(--surface); border: 1px solid var(--border2);
      border-radius: var(--radius-lg); padding: 28px 24px;
      text-align: center; box-shadow: 0 24px 60px rgba(0,0,0,0.5);
      animation: modalIn 0.25s ease;
    }
    .confirm-icon  { font-size: 40px; margin-bottom: 14px; }
    .confirm-title { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
    .confirm-msg   { font-size: 12px; color: var(--text2); line-height: 1.6; margin-bottom: 20px; }
    .confirm-btns  { display: flex; gap: 8px; justify-content: center; }

    /* ── Detail panel ── */
    .detail-header {
      padding: 16px 18px 14px; border-bottom: 1px solid var(--border);
      background: var(--bg3);
    }
    .detail-nama { font-size: 14px; font-weight: 700; margin-bottom: 4px; }
    .detail-kode { font-family: 'JetBrains Mono',monospace; font-size: 10px; color: var(--text3); }
    .detail-body { padding: 14px 18px; }
    .detail-row  { margin-bottom: 11px; }
    .detail-row label {
      display: block; font-size: 9px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.8px;
      color: var(--text3); margin-bottom: 3px;
    }
    .detail-row p { font-size: 12px; color: var(--text2); line-height: 1.5; }
    .detail-row .mono { font-family: 'JetBrains Mono',monospace; font-size: 11px; }
    .detail-actions {
      padding: 12px 18px 16px; border-top: 1px solid var(--border);
      display: flex; gap: 8px;
    }

    /* ── Baris tabel — interaktif ── */
    tbody tr.clickable { cursor: pointer; }
    tbody tr.clickable:hover { background: var(--surface2); }
    tbody tr.row-selected {
      background: rgba(159,239,0,0.05) !important;
      border-left: 2px solid var(--accent);
    }
    td { padding: 10px 12px; font-size: 12px; vertical-align: middle; }
    .td-mono { font-family: 'JetBrains Mono',monospace; font-size: 10px; color: var(--text2); }
    .td-actions { display: flex; gap: 4px; }
    .btn-icon { padding: 5px 7px; border-radius: 6px; }
    @media (max-width: 1100px) {
      .split-view { grid-template-columns: 1fr; }
      .split-detail { position: static; }
    }
    @media (max-width: 900px) {
      .main { margin-left: var(--sidebar-closed) !important; }
      .stats-grid { grid-template-columns: 1fr 1fr; }
      .dash-grid  { grid-template-columns: 1fr; }
    }
    @media (max-width: 600px) {
      .stats-grid { grid-template-columns: 1fr; }
      .content    { padding: 14px 14px 40px; }
      .topbar     { padding: 0 14px; }
      .tb-date    { display: none; }
    }

  </style>
</head>

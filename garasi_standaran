  /* ============================================================
    MODAL HAPUS — handle untuk semua modul
  ============================================================ */
  function konfirmasiHapusMasuk() {
    const mode = document.getElementById('modal-hapus').dataset.mode || 'masuk';
    if (mode === 'keluar') { _eksekusiHapusKeluar(); return; }
    if (mode === 'ops')    { _eksekusiHapusOps();    return; }
    if (mode === 'stok')   { _eksekusiHapusItemStok('stok'); return; }
    if (mode === 'alat')   { _eksekusiHapusItemStok('alat'); return; }
    _eksekusiHapusMasuk();
  }

  function _eksekusiHapusItemStok(tipe) {
    if (!hapusTargetId) return;
    const data   = S.get(tipe, []);
    const target = data.find(b => b.id === hapusTargetId);
    if (!target) { tutupModalHapus(); return; }
    S.set(tipe, data.filter(b => b.id !== hapusTargetId));
    /* reset panel detail jika item yang dihapus sedang ditampilkan */
    if (tipe === 'stok' && selectedStokId === hapusTargetId) {
      selectedStokId = null;
      document.getElementById('detail-empty-stok').style.display   = 'flex';
      document.getElementById('detail-content-stok').style.display = 'none';
    }
    if (tipe === 'alat' && selectedAlatId === hapusTargetId) {
      selectedAlatId = null;
      document.getElementById('detail-empty-alat').style.display   = 'flex';
      document.getElementById('detail-content-alat').style.display = 'none';
    }
    tutupModalHapus();
    showToast(`"${target.nama}" dihapus dari ${tipe === 'stok' ? 'Stok Barang' : 'Alat Kerja'}`, 'success');
    _refreshAll();
  }

  function _eksekusiHapusMasuk() {
    if (!hapusTargetId) return;
    const masuk  = S.get('masuk', []);
    const target = masuk.find(m => m.id === hapusTargetId);
    if (!target) { tutupModalHapus(); return; }

    /* cek stok cukup sebelum mengurangi */
    const itemStok = S.get('stok', []).find(b => b.kode === target.kode);
    if (itemStok && itemStok.stok < target.qty) {
      showToast('Tidak bisa dihapus — sebagian stok sudah terpakai. Hapus transaksi keluar terkait dulu.', 'error');
      tutupModalHapus();
      return;
    }
    _updateStok(target.kode, target.nama, target.kat, target.satuan,
            target.hbeli, target.hjual, target.stokMin, target.ket, -target.qty, target.isAlat);
    _hapusCashflowDariMasuk(hapusTargetId);
    S.set('masuk', masuk.filter(m => m.id !== hapusTargetId));
    if (selectedMasukId === hapusTargetId) {
      selectedMasukId = null;
      document.getElementById('detail-empty-masuk').style.display   = 'flex';
      document.getElementById('detail-content-masuk').style.display = 'none';
    }
    tutupModalHapus();
    showToast(`Transaksi "${target.nama}" dihapus`, 'success');
    _refreshAll();
  }

  function _eksekusiHapusKeluar() {
    if (!hapusTargetId) return;
    const keluar = S.get('keluar', []);
    const target = keluar.find(k => k.id === hapusTargetId);
    if (!target) { tutupModalHapus(); return; }
    /* kembalikan stok */
    const itemStok = S.get('stok', []).find(b => b.kode === target.kode);
    _updateStok(target.kode, target.nama, target.kat, target.satuan,
                itemStok?.hbeli||0, target.hjual, itemStok?.stokMin || 5, target.ket, target.qty, false);
    _hapusCashflowDariKeluar(hapusTargetId);
    S.set('keluar', keluar.filter(k => k.id !== hapusTargetId));
    if (selectedKeluarId === hapusTargetId) {
      selectedKeluarId = null;
      document.getElementById('detail-empty-keluar').style.display   = 'flex';
      document.getElementById('detail-content-keluar').style.display = 'none';
    }
    tutupModalHapus();
    showToast(`Transaksi keluar "${target.nama}" dihapus`, 'success');
    _refreshAll();
  }

  function _eksekusiHapusOps() {
    if (!hapusTargetId) return;
    const ops    = S.get('operasional', []);
    const target = ops.find(o => o.id === hapusTargetId);
    if (!target) { tutupModalHapus(); return; }
    _hapusCashflowDariOps(hapusTargetId);
    S.set('operasional', ops.filter(o => o.id !== hapusTargetId));
    tutupModalHapus();
    showToast(`Biaya "${target.deskripsi}" dihapus`, 'success');
    _refreshAll();
  }


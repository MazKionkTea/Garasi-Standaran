  /* ============================================================
    _refreshAll — render ulang semua halaman sekaligus
  ============================================================ */
  function _refreshAll() {
    renderMasuk();
    renderKeluar();
    renderStok();
    renderAlat();
    renderCashflow();
    renderOps();
    renderLaporan();
    renderDashboard();
  }
  function renderDashboard() {
    const stok  = S.get('stok', []);
    const alat  = S.get('alat', []);
    const masuk = S.get('masuk', []);
    const keluar = S.get('keluar', []);
    const today = hariIni();

    /* semua item inventori (stok + alat) */
    const semuaItem   = [...stok, ...alat];
    const totalItem   = semuaItem.length;
    const menipis     = stok.filter(b => b.stok > 0 && b.stok <= b.stokMin).length;
    const habis       = stok.filter(b => b.stok <= 0).length;
    const nilaiStok   = stok.reduce((a, b) => a + (b.stok * (b.hbeli || 0)), 0);
    const aktivitas   = masuk.filter(m => m.tgl === today).length
                      + keluar.filter(k => k.tgl === today).length;
    const alertCount  = menipis + habis;

    /* update stats card */
    _setStat('sc-total',    totalItem  || '—', totalItem   ? 'jenis barang' : 'belum ada data inventori');
    _setStat('sc-menipis',  alertCount || '—', alertCount  ? `${habis} habis, ${menipis} menipis` : 'semua stok aman');
    _setStat('sc-nilai',    totalItem ? rp(nilaiStok) : '—', totalItem ? 'estimasi nilai stok' : 'belum ada data');
    _setStat('sc-aktivitas', aktivitas || '—', aktivitas ? 'transaksi hari ini' : 'belum ada transaksi');

    /* update badge alert di topbar & sidebar */
    const tbAlert  = document.getElementById('tb-alert');
    const badgeInv = document.getElementById('badge-inv');
    if (alertCount > 0) {
      tbAlert.style.display  = 'flex';
      document.getElementById('tb-alert-txt').textContent = `${alertCount} Stok Menipis`;
      badgeInv.style.display = 'inline';
      badgeInv.textContent   = alertCount;
      /* isi dropdown detail */
      _renderAlertDropdown(stok);
    } else {
      tbAlert.style.display  = 'none';
      badgeInv.style.display = 'none';
    }

    /* update grafik 7 hari */
    const inv = S.get('alat', []);
    const ops = S.get('operasional', []);
    renderChart(masuk, keluar, inv, ops);

    /* update alert list stok menipis */
    renderAlertList(stok);

    /* update grid kategori */
    renderCatGrid(stok, alat);
  }


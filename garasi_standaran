  function simpanInv() {
    const tgl     = document.getElementById('fi-tgl').value;
    const kode    = document.getElementById('fi-kode').value.trim().toUpperCase();
    const nama    = document.getElementById('fi-nama').value.trim();
    const kat     = document.getElementById('fi-kat').value.trim();
    const kondisi = document.getElementById('fi-kondisi').value;
    const satuan  = document.getElementById('fi-satuan').value;
    const qty     = parseInt(document.getElementById('fi-qty').value) || 0;
    const hbeli   = parseInt(document.getElementById('fi-hbeli').value) || 0;
    const ket     = document.getElementById('fi-ket').value.trim();
    const editId  = document.getElementById('fi-id').value;

    if (!tgl)    { showToast('Tanggal wajib diisi', 'error'); return; }
    if (!kode)   { showToast('Kode wajib diisi', 'error'); return; }
    if (!kode.startsWith('INV')) { showToast('Kode harus diawali INV', 'error'); return; }
    if (!nama)   { showToast('Nama alat wajib diisi', 'error'); return; }
    if (!kat)    { showToast('Kategori wajib diisi', 'error'); return; }
    if (!kondisi){ showToast('Kondisi wajib dipilih', 'error'); return; }
    if (!satuan) { showToast('Satuan wajib dipilih', 'error'); return; }
    if (qty < 1) { showToast('Jumlah harus lebih dari 0', 'error'); return; }
    if (!hbeli)  { showToast('Harga beli wajib diisi', 'error'); return; }

    const alat = S.get('alat', []);
    const item = { id: editId || uid(), kode, nama, kat, kondisi, satuan, stok: qty, hbeli, ket, tglBeli: tgl };

    if (editId) {
      const idx = alat.findIndex(a => a.id === editId);
      alat[idx] = item;
      /* hapus cashflow lama, buat baru */
      S.set('cashflow', S.get('cashflow', []).filter(c => c.refId !== editId));
      S.set('operasional', S.get('operasional', []).filter(o => o.refId !== editId));
      _catatCashflowInv(item);
      showToast(`"${nama}" berhasil diperbarui`, 'success');
    } else {
      if (alat.find(a => a.kode === kode)) { showToast(`Kode ${kode} sudah dipakai`, 'error'); return; }
      alat.push(item);
      _catatCashflowInv(item);
      showToast(`"${nama}" berhasil ditambahkan`, 'success');
    }
    S.set('alat', alat);
    tutupFormInv();
    selectedAlatId = item.id;
    _refreshAll();
  }

  function _catatCashflowInv(item) {
    const total = item.stok * item.hbeli;
    if (total <= 0) return;
    /* catat ke cashflow */
    const cf = S.get('cashflow', []);
    cf.push({
      id: uid(), refId: item.id, tgl: item.tglBeli,
      tipe: 'keluar', kategori: 'Pembelian Inventori Bengkel',
      deskripsi: `Beli ${item.nama} (${item.stok} ${item.satuan})`,
      nominal: total, sumber: 'inventori-bengkel',
    });
    S.set('cashflow', cf);
    /* catat ke operasional */
    const ops = S.get('operasional', []);
    ops.push({
      id: uid(), refId: item.id, tgl: item.tglBeli,
      kat: 'Pembelian Inventori Bengkel',
      deskripsi: `Beli ${item.nama} (${item.stok} ${item.satuan})`,
      nominal: total, sumber: 'inventori-bengkel',
    });
    S.set('operasional', ops);
  }


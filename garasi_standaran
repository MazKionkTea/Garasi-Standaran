  function simpanOps() {
    const tgl     = document.getElementById('fo-tgl').value;
    const kat     = document.getElementById('fo-kat').value.trim();
    const desk    = document.getElementById('fo-desk').value.trim();
    const nominal = parseInt(document.getElementById('fo-nominal').value) || 0;
    const editId  = document.getElementById('fo-id').value;

    if (!tgl)    { showToast('Tanggal wajib diisi', 'error'); return; }
    if (!kat)    { showToast('Kategori wajib diisi', 'error'); return; }
    if (!desk)   { showToast('Deskripsi wajib diisi', 'error'); return; }
    if (!nominal){ showToast('Nominal wajib diisi', 'error'); return; }

    const trx = { id: editId || uid(), tgl, kat, deskripsi: desk, nominal, sumber: 'operasional' };
    const ops  = S.get('operasional', []);

    if (editId) {
      const idx = ops.findIndex(o => o.id === editId);
      ops[idx] = trx;
      /* update cashflow */
      _hapusCashflowDariOps(editId);
      showToast('Biaya operasional diperbarui', 'success');
    } else {
      ops.push(trx);
      showToast(`Biaya "${desk}" (${rp(nominal)}) berhasil dicatat`, 'success');
    }
    /* selalu catat ke cashflow sebagai pengeluaran */
    const cf = S.get('cashflow', []);
    cf.push({
      id: uid(), refId: trx.id, tgl: trx.tgl,
      tipe: 'keluar', kategori: trx.kat,
      deskripsi: trx.deskripsi, nominal: trx.nominal,
      sumber: 'operasional',
    });
    S.set('cashflow', cf);
    S.set('operasional', ops);

    tutupFormOps();
    _refreshAll();
  }


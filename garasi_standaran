  /* simpan barang keluar */
  function simpanBarangKeluar() {
    const tgl   = document.getElementById('fk-tgl').value;
    const sel   = document.getElementById('fk-barang');
    const kode  = sel.value;
    const opt   = sel.options[sel.selectedIndex];
    const qty   = parseInt(document.getElementById('fk-qty').value) || 0;
    const hjual     = parseInt(document.getElementById('fk-hjual').value) || 0;
    const ket       = document.getElementById('fk-ket').value.trim();
    const tipeServis = document.getElementById('fk-tipe-servis').checked;
    const jasa      = tipeServis ? (parseInt(document.getElementById('fk-jasa').value) || 0) : 0;
    const editId    = document.getElementById('fk-id').value;

    if (tipeServis && jasa < 1) { showToast('Biaya jasa pasang wajib diisi', 'error'); return; }
    if (kode.toUpperCase().startsWith('INV')) {
      showToast('Inventori bengkel tidak bisa dicatat sebagai barang keluar', 'error'); return;
    }
    if (!tgl)   { showToast('Tanggal wajib diisi', 'error'); return; }
    if (!kode)  { showToast('Pilih barang terlebih dahulu', 'error'); return; }
    if (qty < 1){ showToast('Qty harus lebih dari 0', 'error'); return; }

    const nama   = opt.dataset.nama;
    const satuan = opt.dataset.satuan;
    const stokNow = parseInt(opt.dataset.stok) || 0;

    /* cek stok cukup — saat edit, tambahkan qty lama kembali */
    const keluar   = S.get('keluar', []);
    const qtyLama  = editId ? (keluar.find(k => k.id === editId)?.qty || 0) : 0;
    const stokEfektif = stokNow + qtyLama;
    if (qty > stokEfektif) {
      showToast(`Stok tidak cukup! Tersedia: ${stokEfektif} ${satuan}`, 'error'); return;
    }

    /* ambil kat dari data stok */
    const itemStok = S.get('stok', []).find(b => b.kode === kode);
    const kat = itemStok?.kat || '—';

    const trx = {
      id: editId || uid(),
      tgl, kode, nama, kat, satuan,
      qty, hjual, ket,
      total: qty * hjual,
      tipeServis, jasa,
    };

    if (editId) {
      const idx = keluar.findIndex(k => k.id === editId);
      const lama = keluar[idx];
      keluar[idx] = trx;
      /* kembalikan qty lama ke stok, kurangi qty baru */
      _updateStok(kode, nama, kat, satuan, itemStok?.hbeli||0, hjual, itemStok?.stokMin||5, ket, lama.qty - trx.qty, false);
      /* update cashflow */
      _hapusCashflowDariKeluar(editId);
      _catatCashflowKeluar(trx);
      showToast(`Transaksi "${nama}" diperbarui`, 'success');
    } else {
      keluar.push(trx);
      /* kurangi stok */
      // _updateStok(kode, nama, kat, satuan, hjual, itemStok?.stokMin || 5, ket, -qty, false);
      _updateStok(kode, nama, kat, satuan, itemStok?.hbeli||0, hjual, itemStok?.stokMin||5, ket, -qty, false)
      /* catat pemasukan ke cashflow */
      _catatCashflowKeluar(trx);
      showToast(`Barang "${nama}" keluar (${qty} ${satuan})`, 'success');
    }
    S.set('keluar', keluar);

    tutupFormKeluar();
    selectedKeluarId = trx.id;
    _refreshAll();
  }

  /* catat pemasukan dari penjualan ke cashflow */
  function _catatCashflowKeluar(trx) {
    const cf = S.get('cashflow', []);
    /* entri 1: penjualan barang */
    if (trx.total > 0) {
      cf.push({
        id:        uid(),
        refId:     trx.id,
        tgl:       trx.tgl,
        tipe:      'masuk',
        kategori:  'Penjualan Sparepart',
        deskripsi: `Jual ${trx.nama} (${trx.qty} ${trx.satuan})${trx.ket ? ' — ' + trx.ket : ''}`,
        nominal:   trx.total,
        sumber:    'barang-keluar',
      });
    }
    /* entri 2: jasa pasang (jika ada) */
    if (trx.tipeServis && trx.jasa > 0) {
      cf.push({
        id:        uid(),
        refId:     trx.id,
        tgl:       trx.tgl,
        tipe:      'masuk',
        kategori:  'Jasa Servis',
        deskripsi: `Jasa pasang ${trx.nama}${trx.ket ? ' — ' + trx.ket : ''}`,
        nominal:   trx.jasa,
        sumber:    'barang-keluar',
      });
    }
    S.set('cashflow', cf);
  }
  function _hapusCashflowDariKeluar(refId) {
    S.set('cashflow', S.get('cashflow', []).filter(c => c.refId !== refId));
  }

  /* render tabel barang keluar */
  function renderKeluar() {
    const keluar  = S.get('keluar', []);
    const search  = document.getElementById('keluar-search')?.value.toLowerCase().trim() || '';
    const katFil  = document.getElementById('keluar-filter-kat')?.value || '';
    const bulFil  = document.getElementById('keluar-filter-bulan')?.value || '';

    const filtered = keluar.filter(k => {
      const matchS = !search || [k.nama, k.kode, k.kat, k.ket].join(' ').toLowerCase().includes(search);
      const matchK = !katFil || k.kat === katFil;
      const matchB = !bulFil || k.tgl.startsWith(bulFil);
      return matchS && matchK && matchB;
    }).sort((a, b) => b.tgl.localeCompare(a.tgl));

    const tbody = document.getElementById('tbody-keluar');
    if (!tbody) return;

    tbody.innerHTML = filtered.length === 0
      ? `<tr><td colspan="9"><div class="tbl-empty"><div class="tbl-empty-icon">📤</div>
          <p>${keluar.length === 0
            ? 'Belum ada transaksi keluar.<br>Pastikan ada data di <b>Barang Masuk</b> terlebih dahulu.'
            : 'Tidak ada transaksi yang cocok.'}</p></div></td></tr>`
      : filtered.map(k => `
          <tr class="clickable ${k.id === selectedKeluarId ? 'row-selected' : ''}"
              onclick="selectKeluar('${k.id}')">
            <td class="td-mono">${fmtTgl(k.tgl)}</td>
            <td class="td-mono">${k.kode}</td>
            <td style="font-weight:500">${k.nama}</td>
            <td><span class="badge b-gray">${k.kat}</span></td>
            <td><span style="color:var(--red);font-weight:700;font-family:'JetBrains Mono',monospace">-${k.qty}</span>
                <span style="font-size:10px;color:var(--text3)"> ${k.satuan}</span></td>
            <td class="td-mono">${rp(k.hjual)}</td>
            <td class="td-mono" style="color:var(--accent);font-weight:600">${rp(k.total)}</td>
            <td style="font-size:11px;color:var(--text2)">${k.ket || '—'}</td>
            <td><div class="td-actions">
              <button class="btn btn-ghost btn-sm btn-icon"
                onclick="event.stopPropagation();bukaFormKeluar('${k.id}')" title="Edit">✏️</button>
              <button class="btn btn-red btn-sm btn-icon"
                onclick="event.stopPropagation();konfirmasiHapusKeluar('${k.id}','${k.nama.replace(/'/g,"\\'")}')">🗑️</button>
            </div></td>
          </tr>`).join('');

    /* update filter kategori */
    const sel = document.getElementById('keluar-filter-kat');
    if (sel) {
      const cur  = sel.value;
      const kats = [...new Set(keluar.map(k => k.kat))].filter(Boolean).sort();
      sel.innerHTML = `<option value="">Semua Kategori</option>` +
        kats.map(k => `<option ${k === cur ? 'selected' : ''}>${k}</option>`).join('');
    }

    const total = filtered.reduce((a, k) => a + k.total, 0);
    const elC = document.getElementById('keluar-count');
    const elT = document.getElementById('keluar-total');
    if (elC) elC.textContent = `${filtered.length} transaksi`;
    if (elT) elT.textContent = `Total: ${rp(total)}`;
  }

